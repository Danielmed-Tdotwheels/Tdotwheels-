{%- comment -%}
  Renders a social icon with built-in SVG (default) or a custom uploaded icon.
  Always shows the icon. If a link is provided, it links there; otherwise links to #.

  Usage:
  {% render 'footer-social-link', platform: 'facebook', link: section.settings.facebook_link, custom_icon: section.settings.facebook_icon %}
{%- endcomment -%}

{%- liquid
  assign platform_name = platform | capitalize
  if link == blank
    assign link = '#'
  endif
-%}

<a
  href="{{ link }}"
  aria-label="{{ platform_name }}"
  class="footer-social-icon-wrapper"
  style="color: #ffffff; display: inline-flex; align-items: center; justify-content: center;"
>
  {%- if custom_icon != blank -%}
    <img
      src="{{ custom_icon | image_url: width: 100 }}"
      alt="{{ platform_name }}"
      width="24"
      height="24"
      style="object-fit: contain;"
    >
  {%- else -%}
    {%- case platform -%}
      {%- when 'facebook' -%}
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
          <path d="M22.675 0h-21.35C.597 0 0 .597 0 1.326v21.348C0 23.403.597 24 1.325 24H12.82v-9.294H9.692v-3.622h3.128V8.413c0-3.1 1.893-4.788 4.659-4.788 1.325 0 2.463.099 2.795.143v3.24l-1.918.001c-1.504 0-1.795.715-1.795 1.763v2.31h3.587l-.467 3.622h-3.12V24h6.116c.73 0 1.325-.597 1.325-1.326V1.326C24 .597 23.403 0 22.675 0z"/>
        </svg>
      {%- when 'instagram' -%}
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.668-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
        </svg>
      {%- when 'youtube' -%}
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
          <path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
        </svg>
      {%- when 'tiktok' -%}
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.17-2.81-.6-4.01-1.42-.01 2.23.01 4.46-.01 6.69 0 1.25-.19 2.51-.81 3.61-1.31 2.37-3.91 3.8-6.52 3.66-2.32-.1-4.44-1.38-5.54-3.39-1.28-2.32-1.09-5.36.46-7.5 1.5-2.07 4.1-3.15 6.57-2.61.02 1.5-.02 3.01.03 4.51-1.45-.45-3.14-.07-4.14 1.05-1.02 1.15-1.12 2.9-.27 4.16.89 1.34 2.56 1.95 4.09 1.5 1.48-.44 2.45-1.89 2.45-3.41V.02z"/>
        </svg>
    {%- endcase -%}
  {%- endif -%}
</a>
