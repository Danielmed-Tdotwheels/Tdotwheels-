{% comment %}
  Brand Categories Section - Browse [Brand] Collection
{% endcomment %}

<style>
  .brand-categories-section {
    width: 100%;
    max-width: 1440px;
    margin: 60px auto;
    padding: 0 60px;
    box-sizing: border-box;
  }

  .brand-categories-title {
    font-family: 'Lato', sans-serif;
    font-size: 32px;
    font-weight: 700;
    color: #333;
    margin-bottom: 30px;
  }

  .brand-categories-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
  }

  .brand-category-card {
    position: relative;
    height: 380px;
    border-radius: 4px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 40px;
    box-sizing: border-box;
    text-decoration: none;
    background-color: #f5f5f5;
  }

  .brand-category-image {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 1;
    transition: transform 0.5s ease;
  }

  .brand-category-card:hover .brand-category-image {
    transform: scale(1.05);
  }

  .brand-category-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(0deg, rgba(0, 0, 0, 0.6) 0%, rgba(0, 0, 0, 0) 50%);
    z-index: 2;
  }

  .brand-category-content {
    position: relative;
    z-index: 3;
  }

  .brand-category-label {
    font-family: 'Work Sans', sans-serif;
    font-size: 14px;
    font-weight: 600;
    color: #d72e08;
    text-transform: uppercase;
    margin-bottom: 10px;
    display: block;
  }

  .brand-category-heading {
    font-family: 'Lato', sans-serif;
    font-size: 28px;
    font-weight: 700;
    color: #ffffff;
    margin: 0 0 20px 0;
    max-width: 300px;
    line-height: 1.2;
  }

  .brand-category-btn {
    display: inline-block;
    background-color: #d72e08;
    color: #ffffff;
    font-family: 'Work Sans', sans-serif;
    font-size: 14px;
    font-weight: 600;
    padding: 12px 25px;
    border-radius: 4px;
    transition: background-color 0.3s ease;
  }

  .brand-category-btn:hover {
    background-color: #b02406;
  }

  @media screen and (max-width: 768px) {
    .brand-categories-section {
      padding: 0 20px;
      margin: 40px auto;
    }
    .brand-categories-grid {
      grid-template-columns: 1fr;
    }
    .brand-category-card {
      height: 300px;
      padding: 30px;
    }
    .brand-category-heading {
      font-size: 24px;
    }
  }
</style>

<div class="brand-categories-section">
  <h2 class="brand-categories-title">
    {%- if section.settings.title != blank -%}
      {{ section.settings.title | replace: '[brand]', collection.title }}
    {%- else -%}
      Browse {{ collection.title }} Collection
    {%- endif -%}
  </h2>

  <div class="brand-categories-grid">
    {%- for block in section.blocks -%}
      <a href="{{ block.settings.link }}" class="brand-category-card" {{ block.shopify_attributes }}>
        {%- if block.settings.image != blank -%}
          <img
            src="{{ block.settings.image | image_url: width: 1000 }}"
            alt="{{ block.settings.heading | escape }}"
            class="brand-category-image"
            loading="lazy"
            width="{{ block.settings.image.width }}"
            height="{{ block.settings.image.height }}"
          >
        {%- else -%}
          {{ 'collection-1' | placeholder_svg_tag: 'brand-category-image' }}
        {%- endif -%}

        <div class="brand-category-overlay"></div>

        <div class="brand-category-content">
          <span class="brand-category-label">{{ block.settings.label }}</span>
          <h3 class="brand-category-heading">{{ block.settings.heading }}</h3>
          <span class="brand-category-btn">View Collection</span>
        </div>
      </a>
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "Brand Categories",
  "max_blocks": 2,
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Section Title",
      "default": "Browse [brand] Collection",
      "info": "Use [brand] as a placeholder for the collection title"
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category Card",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Background Image" },
        { "type": "text", "id": "label", "label": "Label", "default": "E-Bikes" },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Comfortable, Efficient, And Built For Everyday Mobility"
        },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Brand Categories",
      "blocks": [
        { "type": "category", "settings": { "label": "E-Bikes" } },
        { "type": "category", "settings": { "label": "Parts" } }
      ]
    }
  ]
}
{% endschema %}
