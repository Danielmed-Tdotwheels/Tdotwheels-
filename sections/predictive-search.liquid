{%- if predictive_search.performed -%}
  <div id="predictive-search-results" class="predictive-search-results">
    {%- if predictive_search.resources.products.size > 0 -%}
      <div class="predictive-search__results-wrapper">
        <div class="predictive-search__products">
          <ul class="predictive-search__list" role="listbox">
            {%- for product in predictive_search.resources.products -%}
              <li class="predictive-search__item" role="option">
                <a href="{{ product.url }}" class="predictive-search__link">
                  <div class="predictive-search__product-image">
                    {%- if product.featured_media != blank -%}
                      <img
                        src="{{ product.featured_media | image_url: width: 120 }}"
                        alt="{{ product.featured_media.alt | escape }}"
                        width="60"
                        height="60"
                        loading="lazy"
                      >
                    {%- else -%}
                      {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
                    {%- endif -%}
                  </div>
                  <div class="predictive-search__product-info">
                    <div class="predictive-search__product-properties">
                      {%- liquid
                        assign is_accessory = false
                        if product.type contains 'Accessory' or product.type contains 'Parts'
                          assign is_accessory = true
                        endif
                        for p_collection in product.collections
                          if p_collection.handle contains 'accessories'
                            assign is_accessory = true
                          endif
                        endfor
                      -%}

                      {%- if is_accessory -%}
                        Accessories and Spare Parts
                      {%- else -%}
                        {%- liquid
                          assign speed = product.metafields.specification.max_speed | default: product.metafields.custom.top_speed | default: '40km/hr'
                          assign range = product.metafields.specification.max_range | default: product.metafields.custom.range | default: '94km'
                          assign battery = product.metafields.specification.power | default: product.metafields.custom.rated_power | default: 'Lithium Batteries'
                        -%}
                        {{ speed }} | {{ range }} | {{ battery }}
                      {%- endif -%}
                    </div>
                    <h3 class="predictive-search__product-title">{{ product.title }}</h3>
                  </div>
                </a>
              </li>
            {%- endfor -%}
          </ul>
        </div>
      </div>
    {%- else -%}
      <div class="predictive-search__no-results">
        <p>No results found for "{{ predictive_search.terms }}".</p>
      </div>
    {%- endif -%}

    <div class="predictive-search__footer">
      <button type="submit" form="PredictiveSearchForm" class="predictive-search__search-all">
        Search for "{{ predictive_search.terms }}"
      </button>
    </div>
  </div>
{%- endif -%}

<style>
  .predictive-search-results {
    background: #ffffff;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
    border-radius: 0 0 12px 12px;
    max-height: 80vh;
    overflow-y: auto;
    width: 100%;
    margin-top: 1px;
  }

  .predictive-search__results-wrapper {
    padding: 10px 0;
  }

  .predictive-search__list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .predictive-search__item {
    border-bottom: 1px solid #f5f5f5;
  }

  .predictive-search__item:last-child {
    border-bottom: none;
  }

  .predictive-search__link {
    display: flex;
    align-items: center;
    padding: 15px 25px;
    text-decoration: none;
    transition: background 0.2s ease;
    gap: 20px;
  }

  .predictive-search__link:hover {
    background: #f9f9f9;
  }

  .predictive-search__product-image {
    width: 64px;
    height: 64px;
    flex-shrink: 0;
    background: #fdfdfd;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .predictive-search__product-image img {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
  }

  .predictive-search__product-info {
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .predictive-search__product-properties {
    font-family: 'Work Sans', sans-serif;
    font-size: 13px;
    color: #999;
    margin-bottom: 4px;
  }

  .predictive-search__product-title {
    font-family: 'Lato', sans-serif;
    font-size: 18px;
    font-weight: 700;
    color: #000;
    margin: 0;
  }

  .predictive-search__no-results {
    padding: 30px;
    text-align: center;
    color: #666;
  }

  .predictive-search__footer {
    padding: 15px 25px;
    background: #fafafa;
    border-top: 1px solid #eee;
  }

  .predictive-search__search-all {
    background: none;
    border: none;
    color: #666;
    font-family: 'Work Sans', sans-serif;
    font-size: 14px;
    cursor: pointer;
    padding: 0;
    width: 100%;
    text-align: left;
    transition: color 0.2s ease;
  }

  .predictive-search__search-all:hover {
    color: #d72308;
    text-decoration: underline;
  }

  @media screen and (max-width: 768px) {
    .predictive-search__link {
      padding: 12px 15px;
      gap: 15px;
    }
    .predictive-search__product-title {
      font-size: 15px;
    }
    .predictive-search__product-properties {
      font-size: 11px;
    }
    .predictive-search__product-image {
      width: 50px;
      height: 50px;
    }
  }
</style>
