{% schema %}
{
  "name": "Brands Grid",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Page Title",
      "default": "Shop by Brand"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 2,
      "max": 5,
      "step": 1,
      "default": 4,
      "label": "Columns per row (Desktop)"
    }
  ],
  "blocks": [
    {
      "type": "brand",
      "name": "Brand",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Brand Collection",
          "info": "Selecting a collection will automatically link the card and pull the brand name and image."
        },
        {
          "type": "text",
          "id": "title",
          "label": "Brand Name Override",
          "info": "Use this to override the collection name (e.g., 'T-Dot Wheels')."
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Brand Logo",
          "info": "Upload a clean logo image. If blank, it will try to use the collection's featured image."
        },
        {
          "type": "url",
          "id": "link",
          "label": "Custom Link Override",
          "info": "Only use this if you want to link somewhere other than the selected collection."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Brands Grid"
    }
  ]
}
{% endschema %}

<style>
  .brands-grid-section {
    padding: 60px 0;
    max-width: 1440px;
    margin: 0 auto;
    padding-left: 2rem;
    padding-right: 2rem;
  }
  .brands-grid-title {
    font-family: 'Lato', sans-serif;
    font-size: 36px;
    font-weight: 700;
    text-align: center;
    margin-bottom: 40px;
  }
  .brands-grid-container {
    display: grid;
    grid-template-columns: repeat({{section.settings.columns_desktop}}, 1fr);
    gap: 30px;
  }
  @media (max-width: 1024px) {
    .brands-grid-container {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  @media (max-width: 768px) {
    .brands-grid-container {
      grid-template-columns: repeat(2, 1fr);
      gap: 15px;
    }
    .brands-grid-section {
      padding: 40px 1rem;
    }
    .brands-grid-title {
      font-size: 28px;
    }
  }
  .brand-grid-item {
    background: #fff;
    border: 1px solid #e5e5e5;
    border-radius: 8px;
    overflow: hidden;
    transition: all 0.3s ease;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 30px;
    min-height: 200px;
    text-decoration: none;
    color: inherit;
  }
  .brand-grid-item:hover {
    box-shadow: 0 10px 20px rgba(0, 0, 0, 0.1);
    transform: translateY(-5px);
    border-color: #d72308;
  }
  .brand-grid-image-container {
    width: 100%;
    height: 100px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 20px;
  }
  .brand-grid-image {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
    transition: transform 0.3s ease;
  }
  .brand-grid-item:hover .brand-grid-image {
    transform: scale(1.05);
  }
  .brand-grid-name {
    font-family: 'Work Sans', sans-serif;
    font-weight: 600;
    font-size: 18px;
    text-align: center;
    color: #333;
  }
  .brand-grid-placeholder {
    width: 100%;
    height: 100%;
    background: #fdfdfd;
    border: 1px dashed #eee;
    border-radius: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #999;
    font-size: 14px;
    font-weight: 500;
  }
</style>

<div class="brands-grid-section">
  {% if section.settings.title != blank %}
    <h1 class="brands-grid-title">{{ section.settings.title }}</h1>
  {% endif %}

  <div class="brands-grid-container">
    {% if section.blocks.size > 0 %}
      {% for block in section.blocks %}
        {%- liquid
          assign collection = block.settings.collection
          assign brand_name = block.settings.title | default: collection.title
          assign brand_handle = brand_name | handleize
          assign brand_logo = block.settings.image | default: collection.featured_image | default: collection.image
          assign brand_logo_url = ''

          if brand_logo == blank
            case brand_handle
              when 'inmotion'
                assign brand_logo_url = 'in.png' | asset_url
              when 'circooter'
                assign brand_logo_url = 'cir.png' | asset_url
              when 'blutron'
                assign brand_logo_url = 'blu.png' | asset_url
              when 'iscooter', 'iscooter-electric-scooters'
                assign brand_logo_url = 'is.png' | asset_url
              when 'isinwheel', 'isinwheel-scooters'
                assign brand_logo_url = 'isin.png' | asset_url
              when 'kaabo'
                assign brand_logo_url = 'kab.png' | asset_url
              when 'segway-ninebot'
                assign brand_logo_url = 'seg.png' | asset_url
              when 't-dot-wheels'
                assign brand_logo_url = 'tdot.png' | asset_url
            endcase
          endif

          # Determine Link
          assign link_url = block.settings.link | default: collection.url
          if link_url == blank
            assign link_url = '/collections/' | append: brand_handle
          endif

          # Append View Suffix for Collections
          if link_url contains '/collections/'
            unless link_url contains '?view='
              if link_url contains '?'
                assign link_url = link_url | append: '&view=about-brand'
              else
                assign link_url = link_url | append: '?view=about-brand'
              endif
            endunless
          endif
        -%}
        <a
          href="{{ link_url }}"
          class="brand-grid-item"
          {{ block.shopify_attributes }}
        >
          <div class="brand-grid-image-container">
            {% if brand_logo != blank %}
              <img
                src="{{ brand_logo | image_url: width: 600 }}"
                alt="{{ brand_name }}"
                class="brand-grid-image"
                width="300"
                height="100"
                loading="lazy"
              >
            {% elsif brand_logo_url != '' and brand_logo_url != blank %}
              <img
                src="{{ brand_logo_url }}"
                alt="{{ brand_name }}"
                class="brand-grid-image"
                width="300"
                height="100"
                loading="lazy"
              >
            {% else %}
              <div class="brand-grid-placeholder">
                <span>{{ brand_name }}</span>
              </div>
            {% endif %}
          </div>
          <div class="brand-grid-name">{{ brand_name }}</div>
        </a>
      {% endfor %}
    {% else %}
      {%- comment -%} Fallback for the 8 requested brands if no blocks are added {%- endcomment -%}
      {%- assign default_brands = 'Blutron,Circooter,Inmotion,iScooter,Isinwheel,Kaabo,Segway Ninebot,T-Dot Wheels'
        | split: ','
      -%}
      {% for brand in default_brands %}
        {%- liquid
          assign handle = brand | handleize
          assign brand_logo_url = ''
          case handle
            when 'inmotion'
              assign brand_logo_url = 'in.png' | asset_url
            when 'circooter'
              assign brand_logo_url = 'cir.png' | asset_url
            when 'blutron'
              assign brand_logo_url = 'blu.png' | asset_url
            when 'iscooter'
              assign brand_logo_url = 'is.png' | asset_url
            when 'isinwheel'
              assign brand_logo_url = 'isin.png' | asset_url
            when 'kaabo'
              assign brand_logo_url = 'kab.png' | asset_url
            when 'segway-ninebot'
              assign brand_logo_url = 'seg.png' | asset_url
            when 't-dot-wheels'
              assign brand_logo_url = 'tdot.png' | asset_url
          endcase
        -%}
        <a href="/collections/{{ handle }}?view=about-brand" class="brand-grid-item">
          {% if brand_logo_url != blank %}
            <img
              src="{{ brand_logo_url }}"
              alt="{{ brand }}"
              class="brand-grid-image"
              width="300"
              height="80"
              loading="lazy"
            >
          {% else %}
            <div class="brand-grid-placeholder">
              <span>Logo for {{ brand }}</span>
            </div>
          {% endif %}
          <div class="brand-grid-name">{{ brand }}</div>
        </a>
      {% endfor %}
    {% endif %}
  </div>
</div>
