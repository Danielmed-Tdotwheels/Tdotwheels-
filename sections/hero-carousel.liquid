{% comment %} Custom Hero Carousel Section - Refined Pro Version {% endcomment %}

<style>
  .hero-carousel {
    width: 100%;
    max-width: 1440px;
    height: 680px;
    margin: 0 auto;
    background-color: #ffffff;
    position: relative;
    overflow: hidden; /* Prevent horizontal scroll */
  }

  .hero-slides-container {
    display: flex;
    width: 100%;
    height: 100%;
    transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
    will-change: transform;
  }

  .hero-slide {
    flex: 0 0 100%;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    padding: 0 60px; /* Adjusted padding for better fit */
    box-sizing: border-box;
    position: relative;
    overflow: hidden;
  }

  /* Left Side: Text Content */
  .hero-text-content {
    width: 800px; /* Reduced from 808 to prevent overflow */
    max-width: 100%;
    z-index: 5;
    position: relative;
    display: flex;
    flex-direction: column;
  }

  .hero-title {
    font-family: 'Lato', sans-serif;
    font-size: 72px; /* Reduced from 88px */
    font-weight: 700;
    color: #000000;
    margin: 0 0 20px 0;
    line-height: 1.1;
    text-align: left;
    width: 700px;
    max-width: 100%;
    word-wrap: break-word;
    order: 1;
    opacity: 0; /* Hidden by default for animation */
  }

  .hero-description {
    font-family: 'Work Sans', sans-serif;
    font-size: 18px;
    font-weight: 400;
    color: #666666;
    width: 650px;
    max-width: 100%;
    margin-bottom: 35px;
    line-height: 1.6;
    text-align: left;
    order: 2;
    opacity: 0; /* Hidden by default for animation */
  }

  /* Entrance Animations */
  @keyframes heroFadeUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes heroImageZoom {
    from {
      opacity: 0;
      transform: scale(0.8) translateY(20px);
    }
    to {
      opacity: 1;
      transform: scale(1) translateY(-5px);
    }
  }

  /* Trigger Animations on Active Slide */
  .hero-slide.is-active .hero-title {
    animation: heroFadeUp 0.8s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
  }
  .hero-slide.is-active .hero-description {
    animation: heroFadeUp 0.8s cubic-bezier(0.2, 0.8, 0.2, 1) 0.2s forwards;
  }
  .hero-slide.is-active .hero-featured-image {
    animation: heroImageZoom 1s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
  }
  .hero-slide.is-active .hero-action-bar {
    animation: heroFadeUp 0.8s cubic-bezier(0.2, 0.8, 0.2, 1) 0.3s forwards;
  }

  /* Reset states for non-active slides */
  .hero-slide:not(.is-active) .hero-title,
  .hero-slide:not(.is-active) .hero-description,
  .hero-slide:not(.is-active) .hero-action-bar {
    opacity: 0;
  }
  .hero-slide:not(.is-active) .hero-featured-image {
    opacity: 0;
    transform: scale(0.8);
  }

  /* Product Selection Thumbnails */
  .hero-slide-nav {
    display: flex;
    gap: 12px;
    margin-bottom: 35px;
    order: 3; /* Above buttons on desktop */
  }

  .hero-nav-item {
    width: 80px;
    height: 80px;
    border-radius: 8px;
    border: 1px solid #e5e5e5;
    padding: 8px;
    box-sizing: border-box;
    cursor: pointer;
    background: #f9f9f9;
    transition: all 0.3s ease;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .hero-nav-item.active {
    border: 2px solid #d72e08;
    background: #ffffff;
  }

  .hero-nav-item img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  /* Action Bar: Button & Price */
  .hero-action-bar {
    display: flex;
    align-items: center;
    gap: 30px;
    order: 4; /* Below thumbnails on desktop */
  }

  .hero-buy-btn {
    background-color: #d72e08;
    color: #ffffff;
    font-family: 'Work Sans', sans-serif;
    font-size: 16px;
    font-weight: 600;
    text-decoration: none;
    padding: 15px 35px;
    border-radius: 50px;
    display: inline-flex;
    align-items: center;
    gap: 10px;
    transition: background-color 0.3s ease;
  }

  .hero-buy-btn:hover {
    background-color: #b02406;
  }

  .hero-btn-arrow {
    width: 12px;
    height: 12px;
    fill: currentColor;
  }

  .hero-price-display {
    display: flex;
    align-items: center;
    gap: 12px;
    font-family: 'Work Sans', sans-serif;
  }

  .hero-price-now {
    font-size: 22px;
    font-weight: 700;
    color: #d72e08;
  }

  .hero-price-was {
    font-size: 16px; /* Reduced for mobile/desktop balance */
    font-weight: 400;
    color: #999999;
    text-decoration: line-through;
  }

  /* Right Side: Visual Content */
  .hero-visual-content {
    flex: 1;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1;
  }

  .hero-prop-wrapper {
    position: relative;
    width: 500px; /* Reduced to 500px as requested */
    height: 500px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .hero-red-prop {
    position: absolute;
    width: 100%;
    height: 100%;
    z-index: 1;
    object-fit: contain;
  }

  .hero-featured-image {
    position: relative;
    z-index: 2;
    max-width: 115%; /* increased to overlap circle */
    max-height: 115%; /* increased to overlap circle */
    object-fit: contain;
    transform: translateY(-5px); /* subtle lift to enhance pop-out */
  }

  /* Navigation Arrows */
  .hero-navigation-controls {
    position: absolute;
    bottom: 30px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 20px;
    z-index: 15;
    align-items: center;
  }

  .hero-nav-arrow-prev {
    cursor: pointer;
    background: none;
    border: none;
    padding: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.2s ease;
  }

  .hero-nav-arrow-prev svg {
    width: 16px;
    height: 16px;
    fill: #cccccc;
  }

  .hero-nav-arrow-next {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background-color: #d72e08;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: transform 0.2s ease;
  }

  .hero-nav-arrow-next svg {
    width: 14px;
    height: 14px;
    fill: #ffffff;
  }

  .hero-nav-arrow-prev:hover,
  .hero-nav-arrow-next:hover {
    transform: scale(1.1);
  }

  /* Mobile Specific Arrows in Thumb Row */
  .hero-mobile-arrow {
    display: none;
    cursor: pointer;
    align-items: center;
    justify-content: center;
    transition: transform 0.2s ease;
  }

  .hero-mobile-arrow-prev svg {
    width: 24px;
    height: 24px;
    fill: #cccccc;
  }

  .hero-mobile-arrow-next {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background-color: #d72e08;
  }

  .hero-mobile-arrow-next svg {
    width: 16px;
    height: 16px;
    fill: #ffffff;
  }

  @media screen and (max-width: 1024px) {
    .hero-carousel {
      height: auto;
      padding-bottom: 40px;
    }
    .hero-slide {
      flex-direction: column;
      padding: 30px 20px;
      height: auto;
      align-items: center; /* Center align for visual balance, text can override */
    }
    .hero-text-content {
      display: contents; /* Remove container box so children can be reordered with visual content */
    }

    /* 1. Image */
    .hero-visual-content {
      order: 1;
      width: 100%;
      justify-content: center;
      margin-top: 0;
      margin-bottom: 15px;
    }

    /* 2. Product Title */
    .hero-title {
      order: 2;
      font-size: 28px;
      text-align: left;
      width: 100%;
      margin: 0 0 10px 0;
    }

    /* 3. Product Description */
    .hero-description {
      order: 3;
      font-size: 15px;
      width: 100%;
      text-align: left;
      margin-bottom: 20px;
    }

    /* 4. Call to Action */
    .hero-action-bar {
      order: 4;
      display: flex;
      flex-direction: row;
      align-items: center;
      gap: 15px;
      margin-bottom: 25px;
      width: 100%;
    }

    /* 5. Square Image Boxes */
    .hero-slide-nav {
      order: 5;
      justify-content: flex-start;
      gap: 10px;
      margin-bottom: 20px;
      width: 100%;
    }

    .hero-buy-btn {
      padding: 12px 25px;
      font-size: 14px;
      white-space: nowrap;
    }
    .hero-price-now {
      font-size: 18px;
    }
    .hero-price-was {
      font-size: 14px;
    }
    .hero-nav-item {
      width: 70px;
      height: 70px;
      flex-shrink: 0;
    }
    .hero-mobile-arrow {
      display: flex;
    }
    .hero-slide-nav {
      align-items: center;
      gap: 15px;
    }
    .hero-prop-wrapper {
      width: 240px;
      height: 240px;
    }
    .hero-navigation-controls {
      display: none !important;
    }
    /* Re-enabling nav controls if desired, or let them sit at the very bottom */
    .hero-navigation-controls {
      display: flex;
      order: 6; /* Ensure it stays at bottom if it was direct child, it is direct child of carousel not slide, so this order doesn't affect it relative to slide content but relative to other carousel children? No, it's outside hero-slide. */
    }
  }
</style>

<div class="hero-carousel" id="heroCarouselWrapper-{{ section.id }}">
  <div
    class="hero-slides-container"
    id="heroSlidesStrip-{{ section.id }}"
    style="display: flex; transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1); width: 100%;"
  >
    {%- for block in section.blocks -%}
      {%- assign product = all_products[block.settings.product] -%}
      {%- if product == empty -%}
        {%- assign product = collections.all.products[forloop.index0] -%}
      {%- endif -%}

      <div
        class="hero-slide"
        {{ block.shopify_attributes }}
      >
        <div class="hero-text-content">
          <h1 class="hero-title">
            {%- if block.settings.heading != blank -%}
              {{ block.settings.heading }}
            {%- elsif product != empty -%}
              {{ product.title }}
            {%- else -%}
              Trending F1 Scooter By Inmotion
            {%- endif -%}
          </h1>
          <p class="hero-description">
            {%- if block.settings.description != blank -%}
              {{ block.settings.description }}
            {%- elsif product != empty -%}
              {{ product.description | strip_html | truncatewords: 35 }}
            {%- else -%}
              Premium electric scooters, e-bikes, and accessories for the modern commuter. Quality that lasts, shipping
              that flies with 60km range + 45km/h speed and 35% hill grade.
            {%- endif -%}
          </p>

          <div class="hero-action-bar">
            <a href="{% if product != empty %}{{ product.url }}{% else %}#{% endif %}" class="hero-buy-btn">
              Buy Now
              <svg class="hero-btn-arrow" viewBox="0 0 32 32" width="12" height="12">
                <path d="M11 8l8 8-8 8 2 2 10-10-10-10z"/>
              </svg>
            </a>
            <div class="hero-price-display">
              <span class="hero-price-now">
                {% if product != empty %}{{ product.price | money }}{% else %}$1,099.00{% endif %}
              </span>
              {%- if product != empty and product.compare_at_price > product.price -%}
                <span class="hero-price-was">{{ product.compare_at_price | money }}</span>
              {%- endif -%}
            </div>
          </div>

          <!-- Thumbnail Navigation -->
          <div class="hero-slide-nav hero-nav-sync-{{ section.id }}">
            <div
              class="hero-mobile-arrow hero-mobile-arrow-prev"
              onclick="moveHeroPrev{{ section.id | replace: '-', '_' }}()"
            >
              <svg viewBox="0 0 32 32">
                <path d="M21 24l-8-8 8-8-2-2-10 10 10 10z"/>
              </svg>
            </div>

            {%- for nav_block in section.blocks -%}
              {%- assign nav_product = all_products[nav_block.settings.product] -%}
              {%- if nav_product == empty -%}
                {%- assign nav_product = collections.all.products[forloop.index0] -%}
              {%- endif -%}
              <div
                class="hero-nav-item {% if forloop.index0 == forloop.parentloop.index0 %}active{% endif %}"
                onclick="jumpToHeroSlide{{ section.id | replace: '-', '_' }}({{ forloop.index0 }})"
              >
                {%- if nav_product != empty -%}
                  <img
                    src="{{ nav_product.featured_image | image_url: width: 240 }}"
                    alt="{{ nav_product.title }}"
                    width="80"
                    height="80"
                  >
                {%- else -%}
                  {{ 'product-apparel-1' | placeholder_svg_tag }}
                {%- endif -%}
              </div>
            {%- endfor -%}

            <div
              class="hero-mobile-arrow hero-mobile-arrow-next"
              onclick="moveHeroNext{{ section.id | replace: '-', '_' }}()"
            >
              <svg viewBox="0 0 32 32">
                <path d="M11 8l8 8-8 8 2 2 10-10-10-10z"/>
              </svg>
            </div>
          </div>
        </div>

        <div class="hero-visual-content">
          <div class="hero-prop-wrapper">
            <img
              src="{{ 'hero-red-circle.png' | asset_url }}"
              class="hero-red-prop"
              alt="Prop"
              width="650"
              height="650"
            >
            {%- if product != empty -%}
              <img
                src="{{ product.featured_image | image_url: width: 1000 }}"
                class="hero-featured-image"
                alt="{{ product.title }}"
                width="600"
                height="600"
              >
            {%- else -%}
              <div
                class="hero-featured-image"
                style="width: 100%; max-width: 600px; height: auto; aspect-ratio: 1; opacity: 0.8;"
              >
                {{ 'product-apparel-1' | placeholder_svg_tag }}
              </div>
            {%- endif -%}
          </div>
        </div>
      </div>
    {%- endfor -%}
  </div>

  <div class="hero-navigation-controls">
    <div class="hero-nav-arrow-prev" onclick="moveHeroPrev{{ section.id | replace: '-', '_' }}()">
      <svg viewBox="0 0 32 32">
        <path d="M21 24l-8-8 8-8-2-2-10 10 10 10z"/>
      </svg>
    </div>
    <div class="hero-nav-arrow-next" onclick="moveHeroNext{{ section.id | replace: '-', '_' }}()">
      <svg viewBox="0 0 32 32">
        <path d="M11 8l8 8-8 8 2 2 10-10-10-10z"/>
      </svg>
    </div>
  </div>
</div>

<script>
  (function() {
    let currentIdx = 0;
    const count = {{ section.blocks.size }};
    const strip = document.getElementById('heroSlidesStrip-{{ section.id }}');
    const syncClass = '.hero-nav-sync-{{ section.id }}';
    const slides = strip.querySelectorAll('.hero-slide');
    let autoplayTimer;

    function update() {
      if (!strip) return;
      strip.style.transform = `translateX(-${currentIdx * 100}%)`;
      
      // Update Active Slide Classes
      slides.forEach((slide, idx) => {
        slide.classList.toggle('is-active', idx === currentIdx);
      });

      // Update Thumbnails
      const allNavs = document.querySelectorAll(syncClass);
      allNavs.forEach(nav => {
        const items = nav.querySelectorAll('.hero-nav-item');
        items.forEach((item, idx) => {
          item.classList.toggle('active', idx === currentIdx);
        });
      });
      
      resetAutoplay();
    }

    function resetAutoplay() {
      clearInterval(autoplayTimer);
      autoplayTimer = setInterval(() => {
        window.moveHeroNext{{ section.id | replace: '-', '_' }}();
      }, 5000); // 5 Seconds
    }

    // Initial Activation
    update();

    // Pause on hover
    const wrapper = document.getElementById('heroCarouselWrapper-{{ section.id }}');
    wrapper.addEventListener('mouseenter', () => clearInterval(autoplayTimer));
    wrapper.addEventListener('mouseleave', () => resetAutoplay());

    window.moveHeroNext{{ section.id | replace: '-', '_' }} = function() {
      currentIdx = (currentIdx + 1) % count;
      update();
    };

    window.moveHeroPrev{{ section.id | replace: '-', '_' }} = function() {
      currentIdx = (currentIdx - 1 + count) % count;
      update();
    };

    window.jumpToHeroSlide{{ section.id | replace: '-', '_' }} = function(idx) {
      currentIdx = idx;
      update();
    };
  })();
</script>

{% schema %}
{
  "name": "Hero Carousel",
  "max_blocks": 5,
  "settings": [],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Custom Heading",
          "info": "Leave blank to use product title"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Custom Description",
          "info": "Leave blank to use product description snippet"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero Carousel",
      "blocks": [{ "type": "slide" }, { "type": "slide" }, { "type": "slide" }]
    }
  ]
}
{% endschema %}
