{% comment %}
  Refined Our Company Hero - Integrated & Professional Tdot Wheels Redesign
{% endcomment %}

{% style %}
  .company-hero-{{ section.id }} {
    position: relative;
    width: 100%;
    background-color: {{ section.settings.bg_color }};
    overflow: hidden;
    padding: 100px 0 80px 0;
  }

  /* Decorative Background Element */
  .company-hero-{{ section.id }}::before {
    content: '';
    position: absolute;
    top: -10%;
    right: -5%;
    width: 40%;
    height: 60%;
    background: radial-gradient(circle, {{ section.settings.accent_color | color_modify: 'alpha', 0.05 }} 0%, transparent 70%);
    z-index: 1;
    pointer-events: none;
    border-radius: 50%;
  }

  .company-hero-{{ section.id }} .page-width {
    display: flex;
    align-items: center;
    gap: 80px;
    max-width: 1300px;
    margin: 0 auto;
    padding: 0 40px;
  }

  .hero-text-content {
    flex: 1.3;
    z-index: 3;
    opacity: 0;
    transform: translateY(20px);
    transition: all 1.2s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .hero-text-content.active {
    opacity: 1;
    transform: translateY(0);
  }

  .hero-visual-content {
    flex: 1;
    position: relative;
    z-index: 2;
    border-radius: 24px;
    overflow: hidden;
    box-shadow: 0 40px 80px rgba(0,0,0,0.15);
    min-height: 500px;
    opacity: 0;
    transform: scale(0.95) translateX(30px);
    transition: all 1.4s cubic-bezier(0.16, 1, 0.3, 1) 0.3s;
  }

  .hero-visual-content.active {
    opacity: 1;
    transform: scale(1) translateX(0);
  }

  .hero-visual-content img,
  .hero-visual-content video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 10s linear;
  }

  .hero-visual-content:hover img {
    transform: scale(1.1);
  }

  .hero-tagline {
    font-family: 'Work Sans', sans-serif;
    font-size: 13px;
    font-weight: 800;
    letter-spacing: 4px;
    text-transform: uppercase;
    color: {{ section.settings.accent_color }};
    margin-bottom: 20px;
    display: inline-block;
    padding-bottom: 4px;
    border-bottom: 2px solid {{ section.settings.accent_color | color_modify: 'alpha', 0.3 }};
  }

  .hero-title {
    font-family: 'Lato', sans-serif;
    font-size: clamp(40px, 6vw, 64px);
    font-weight: 900;
    line-height: 1.05;
    margin: 0 0 24px 0;
    color: #111;
    letter-spacing: -1px;
  }

  .hero-description {
    font-family: 'Work Sans', sans-serif;
    font-size: 19px;
    line-height: 1.5;
    color: #333;
    margin-bottom: 48px;
    max-width: 600px;
    font-weight: 400;
  }

  .roots-integration {
    border-top: 1px solid rgba(0,0,0,0.1);
    padding-top: 40px;
    position: relative;
  }

  .roots-integration::after {
     content: '';
     position: absolute;
     top: -1px;
     left: 0;
     width: 80px;
     height: 1px;
     background: {{ section.settings.accent_color }};
  }

  .roots-eyebrow {
    font-size: 12px;
    font-weight: 800;
    letter-spacing: 3px;
    color: #999;
    text-transform: uppercase;
    margin-bottom: 14px;
    display: block;
  }

  .roots-heading {
    font-family: 'Lato', sans-serif;
    font-size: 26px;
    font-weight: 800;
    color: #111;
    margin-bottom: 18px;
    line-height: 1.3;
  }

  .roots-text {
    font-family: 'Work Sans', sans-serif;
    font-size: 17px;
    line-height: 1.7;
    color: #4a4a4a;
  }

  @media screen and (max-width: 1024px) {
    .company-hero-{{ section.id }} .page-width {
      flex-direction: column;
      text-align: center;
      padding: 0 30px;
      gap: 50px;
    }
    .hero-visual-content {
      width: 100%;
      min-height: 400px;
      order: -1;
    }
    .hero-description {
      margin-left: auto;
      margin-right: auto;
    }
    .roots-integration::after {
      left: 50%;
      transform: translateX(-50%);
    }
  }

  @media screen and (max-width: 768px) {
     .company-hero-{{ section.id }} {
      padding: 60px 0;
    }
    .hero-title {
      font-size: 36px;
    }
    .hero-visual-content {
      min-height: 300px;
    }
  }
{% endstyle %}

<section class="company-hero-{{ section.id }}" id="CompanyHero">
  <div class="page-width">
    <div class="hero-text-content">
      <span class="hero-tagline">{{ section.settings.tagline }}</span>
      <h1 class="hero-title">{{ section.settings.title }}</h1>
      <p class="hero-description">{{ section.settings.description }}</p>
      
      {%- if section.settings.roots_heading != blank -%}
        <div class="roots-integration">
          <span class="roots-eyebrow">{{ section.settings.roots_eyebrow }}</span>
          <h2 class="roots-heading">{{ section.settings.roots_heading }}</h2>
          <div class="roots-text">{{ section.settings.roots_text }}</div>
        </div>
      {%- endif -%}
    </div>

    <div class="hero-visual-content">
      {%- if section.settings.video_url != blank -%}
        <video autoplay muted loop playsinline poster="{{ section.settings.image | image_url: width: 1200 }}">
          <source src="{{ section.settings.video_url }}" type="video/mp4">
        </video>
      {%- elsif section.settings.image != blank -%}
        <img
          src="{{ section.settings.image | image_url: width: 1200 }}"
          alt="{{ section.settings.image.alt | escape }}"
          width="{{ section.settings.image.width }}"
          height="{{ section.settings.image.height }}"
          loading="eager"
        >
      {%- else -%}
        {{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder-svg' }}
      {%- endif -%}
    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const text = document.querySelector('.hero-text-content');
    const visual = document.querySelector('.hero-visual-content');
    setTimeout(() => {
      if(text) text.classList.add('active');
      if(visual) visual.classList.add('active');
    }, 150);
  });
</script>

{% schema %}
{
  "name": "Refined Company Hero",
  "settings": [
    {
      "type": "header",
      "content": "Hero Main Content"
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "Tagline",
      "default": "SINCE 2022"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Our Company"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Accelerating the adoption of e-mobility across Canada."
    },
    {
      "type": "header",
      "content": "Integrated Roots Content"
    },
    {
      "type": "text",
      "id": "roots_eyebrow",
      "label": "Roots Eyebrow",
      "default": "OUR ROOTS"
    },
    {
      "type": "text",
      "id": "roots_heading",
      "label": "Roots Heading",
      "default": "Leading Canada's E-Mobility Evolution"
    },
    {
      "type": "richtext",
      "id": "roots_text",
      "label": "Roots Text"
    },
    {
      "type": "header",
      "content": "Media & Style"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Hero Image"
    },
    {
      "type": "text",
      "id": "video_url",
      "label": "Video URL (MP4 Link)"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent Color",
      "default": "#d72e08"
    }
  ],
  "presets": [
    {
      "name": "Refined Company Hero"
    }
  ]
}
{% endschema %}
