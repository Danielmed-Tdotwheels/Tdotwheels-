{% comment %}
  Refined Our Company Content Section - Premium UI & Animations Redesign
{% endcomment %}

{% style %}
  :root {
    --accent-red: {{ section.settings.accent_color | default: '#d72e08' }};
    --text-main: #111111;
    --text-muted: #555555;
    --bg-light: #fdfdfd;
    --glass-bg: rgba(255, 255, 255, 0.7);
    --glass-border: rgba(0, 0, 0, 0.05);
  }

  .company-content-{{ section.id }} {
    max-width: 1300px;
    margin: 0 auto;
    padding: 100px 40px;
    font-family: 'Work Sans', sans-serif;
    overflow: hidden;
  }

  /* Global Animation Classes */
  .reveal-up {
    opacity: 0;
    transform: translateY(40px);
    transition: all 1s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .reveal-up.active {
    opacity: 1;
    transform: translateY(0);
  }

  .stagger-item {
    opacity: 0;
    transform: translateY(20px);
    transition: all 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .stagger-item.active {
    opacity: 1;
    transform: translateY(0);
  }

  /* Story Block Redesign - Modern Glass Cards */
  .story-card {
    display: flex;
    align-items: center;
    gap: 80px;
    margin-bottom: 120px;
    position: relative;
  }

  .story-card.layout-stacked {
    flex-direction: column;
    text-align: center;
    gap: 40px;
  }

  .story-card.reverse {
    flex-direction: row-reverse;
  }

  .story-media {
    flex: 1;
    position: relative;
    border-radius: 24px;
    overflow: hidden;
    box-shadow: 0 30px 60px rgba(0,0,0,0.08);
    background: #f4f4f4;
    aspect-ratio: 4/3;
  }

  .story-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 1.2s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .story-card:hover .story-media img {
    transform: scale(1.05);
  }

  .story-text {
    flex: 1;
    padding: 20px 0;
  }

  .story-eyebrow {
    font-size: 13px;
    font-weight: 800;
    letter-spacing: 3px;
    color: var(--accent-red);
    margin-bottom: 16px;
    display: block;
    text-transform: uppercase;
  }

  .story-heading {
    font-family: 'Lato', sans-serif;
    font-size: clamp(32px, 4vw, 42px);
    font-weight: 900;
    margin: 0 0 24px 0;
    color: var(--text-main);
    line-height: 1.15;
    letter-spacing: -0.5px;
  }

  .story-body {
    font-size: 18px;
    line-height: 1.7;
    color: var(--text-muted);
  }

  /* Mission Block - Premium Focus */
  .mission-wrapper {
    background: var(--bg-light);
    border: 1px solid var(--glass-border);
    border-radius: 32px;
    padding: 100px 60px;
    text-align: center;
    max-width: 1000px;
    margin: 120px auto;
    position: relative;
    box-shadow: 0 10px 40px rgba(0,0,0,0.02);
  }

  .mission-quote-icon {
    position: absolute;
    top: 40px;
    left: 50%;
    transform: translateX(-50%);
    font-size: 60px;
    color: var(--accent-red);
    opacity: 0.15;
    font-family: 'Lato', serif;
    line-height: 1;
  }

  .mission-heading {
    font-family: 'Lato', sans-serif;
    font-size: 40px;
    font-weight: 900;
    color: var(--text-main);
    margin-bottom: 30px;
    letter-spacing: -1px;
  }

  .mission-text {
    font-family: 'Work Sans', sans-serif;
    font-size: clamp(20px, 3vw, 26px);
    font-weight: 600;
    color: var(--accent-red);
    line-height: 1.4;
    max-width: 800px;
    margin: 0 auto;
    position: relative;
    opacity: 0.85;
  }

  /* Ecosystem Grid - Interactive & Sharp */
  .ecosystem-container {
    padding: 80px 0;
    text-align: center;
  }

  .ecosystem-header {
    margin-bottom: 60px;
  }

  .ecosystem-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
  }

  .ecosystem-card {
    background: #ffffff;
    border: 1px solid #eeeeee;
    border-radius: 20px;
    padding: 40px 24px;
    transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
    text-decoration: none;
    color: inherit;
    position: relative;
  }

  .ecosystem-card:hover {
    transform: translateY(-12px);
    box-shadow: 0 30px 60px rgba(0,0,0,0.1);
    border-color: var(--accent-red);
  }

  .ecosystem-icon-box {
    width: 80px;
    height: 80px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 32px;
    background: #fafafa;
    border-radius: 24px;
    transition: all 0.4s ease;
    overflow: hidden;
  }

  .ecosystem-card:hover .ecosystem-icon-box {
    background: #fff5f3;
    transform: rotate(5deg) scale(1.1);
  }

  .ecosystem-card h4 {
    font-size: 18px;
    font-weight: 700;
    margin: 0;
    color: var(--text-main);
  }

  .ecosystem-card span {
    font-size: 14px;
    color: #888;
    font-weight: 500;
  }

  @media screen and (max-width: 1024px) {
    .story-card {
      flex-direction: column !important;
      text-align: center;
      gap: 40px;
      margin-bottom: 80px;
    }
    .story-media {
      width: 100%;
      aspect-ratio: 16/9;
    }
    .ecosystem-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media screen and (max-width: 768px) {
    .company-content-{{ section.id }} {
      padding: 60px 24px;
    }
    .mission-wrapper {
      padding: 60px 30px;
    }
    .ecosystem-grid {
      grid-template-columns: 1fr;
    }
  }
{% endstyle %}

<section class="company-content-{{ section.id }}" id="CompanyContent">
  {%- for block in section.blocks -%}
    {%- case block.type -%}
      {%- when 'story_block' -%}
        <div class="story-card reveal-up {% if block.settings.layout == 'stacked' %}layout-stacked{% endif %} {% if block.settings.reverse and block.settings.layout != 'stacked' %}reverse{% endif %}" {{ block.shopify_attributes }}>
          <div class="story-media">
            {%- if block.settings.image != blank -%}
              <img
                src="{{ block.settings.image | image_url: width: 1200 }}"
                alt="{{ block.settings.heading | escape }}"
                loading="lazy"
                width="800"
                height="600"
              >
            {%- else -%}
              {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
            {%- endif -%}
          </div>
          <div class="story-text">
            <span class="story-eyebrow">{{ block.settings.eyebrow }}</span>
            <h2 class="story-heading">{{ block.settings.heading }}</h2>
            <div class="story-body">{{ block.settings.text }}</div>
          </div>
        </div>

      {%- when 'mission_block' -%}
        <div class="mission-wrapper reveal-up" {{ block.shopify_attributes }}>
          <div class="mission-quote-icon">“</div>
          <h2 class="mission-heading">{{ block.settings.heading }}</h2>
          <p class="mission-text">{{ block.settings.text }}</p>
        </div>

      {%- when 'ecosystem_block' -%}
        <div class="ecosystem-container" {{ block.shopify_attributes }}>
          <div class="ecosystem-header reveal-up">
            <span class="story-eyebrow">{{ block.settings.eyebrow }}</span>
            <h2 class="story-heading">{{ block.settings.heading }}</h2>
          </div>
          <div class="ecosystem-grid">
            {%- for i in (1..4) -%}
              {%- assign image_key = 'image_' | append: i -%}
              {%- assign title_key = 'title_' | append: i -%}
              {%- assign url_key = 'url_' | append: i -%}
              {%- assign img = block.settings[image_key] -%}
              {%- assign title = block.settings[title_key] -%}
              {%- assign url = block.settings[url_key] -%}
              
              {%- if title != blank or img != blank -%}
                <a {% if url != blank %}href="{{ url }}"{% endif %} class="ecosystem-card stagger-item">
                  <div class="ecosystem-icon-box">
                    {%- if img != blank -%}
                      <img src="{{ img | image_url: width: 160 }}" alt="{{ title }}" width="80" height="100" style="width:100%;height:100%;object-fit:contain;" loading="lazy">
                    {%- else -%}
                      {% case i %}
                        {% when 1 %}🛴
                        {% when 2 %}🎒
                        {% when 3 %}🎮
                        {% when 4 %}🏋️
                      {% endcase %}
                    {%- endif -%}
                  </div>
                  <h4>{{ title }}</h4>
                  <span>Explore Collection →</span>
                </a>
              {%- endif -%}
            {%- endfor -%}
          </div>
        </div>
    {%- endcase -%}
  {%- endfor -%}
</section>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const observerOptions = {
      root: null,
      threshold: 0.15,
      rootMargin: '0px 0px -50px 0px'
    };

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('active');
          
          // If it's the ecosystem container, stagger its items
          if (entry.target.classList.contains('ecosystem-container')) {
             const items = entry.target.querySelectorAll('.stagger-item');
             items.forEach((item, index) => {
               setTimeout(() => {
                 item.classList.add('active');
               }, index * 150);
             });
          }

          // If it's a grid container (general), stagger items inside
          const staggers = entry.target.querySelectorAll('.stagger-item:not(.active)');
          staggers.forEach((item, index) => {
             setTimeout(() => {
               item.classList.add('active');
             }, index * 100);
          });
        }
      });
    }, observerOptions);

    const revealElements = document.querySelectorAll('.reveal-up, .ecosystem-container');
    revealElements.forEach(el => observer.observe(el));
  });
</script>

{% schema %}
{
  "name": "Refined Company Content",
  "blocks": [
    {
      "type": "story_block",
      "name": "Story Block",
      "settings": [
        {
          "type": "select",
          "id": "layout",
          "label": "Layout Style",
          "options": [
            { "value": "side_by_side", "label": "Side by Side (2 Col)" },
            { "value": "stacked", "label": "Stacked (1 Col)" }
          ],
          "default": "side_by_side"
        },
        {
          "type": "text",
          "id": "eyebrow",
          "label": "Eyebrow Text"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Text"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Section Image"
        },
        {
          "type": "checkbox",
          "id": "reverse",
          "label": "Reverse Side-by-Side",
          "default": false
        }
      ]
    },
    {
      "type": "mission_block",
      "name": "Mission Block",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Our Mission"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Mission Text"
        }
      ]
    },
    {
      "type": "ecosystem_block",
      "name": "Ecosystem Grid",
      "settings": [
        {
          "type": "text",
          "id": "eyebrow",
          "label": "Eyebrow",
          "default": "OUR PROGRESSION"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "A Growing Product Ecosystem"
        },
        { "type": "header", "content": "Item 1" },
        { "type": "image_picker", "id": "image_1", "label": "Image 1" },
        { "type": "text", "id": "title_1", "label": "Title 1", "default": "E-Mobility" },
        { "type": "url", "id": "url_1", "label": "Link 1" },
        { "type": "header", "content": "Item 2" },
        { "type": "image_picker", "id": "image_2", "label": "Image 2" },
        { "type": "text", "id": "title_2", "label": "Title 2", "default": "Travel Gear" },
        { "type": "url", "id": "url_2", "label": "Link 2" },
        { "type": "header", "content": "Item 3" },
        { "type": "image_picker", "id": "image_3", "label": "Image 3" },
        { "type": "text", "id": "title_3", "label": "Title 3", "default": "Gaming Gear" },
        { "type": "url", "id": "url_3", "label": "Link 3" },
        { "type": "header", "content": "Item 4" },
        { "type": "image_picker", "id": "image_4", "label": "Image 4" },
        { "type": "text", "id": "title_4", "label": "Title 4", "default": "Fitness" },
        { "type": "url", "id": "url_4", "label": "Link 4" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Refined Company Content"
    }
  ]
}
{% endschema %}
