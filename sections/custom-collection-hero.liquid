{% comment %} Custom Collection Hero - Final Polish {% endcomment %}
<div id="heroCarouselWrapper-{{ section.id }}">
  <style>
    .collection-hero {
      width: 100%;
      max-width: 1440px;
      height: 680px;
      margin: 0 auto;
      background-color: #ffffff;
      position: relative;
      overflow: hidden;
    }

    .hero-slides-container {
      display: flex;
      width: 100%;
      height: 100%;
      transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
      will-change: transform;
    }

    .hero-slide {
      flex: 0 0 100%;
      width: 100%;
      height: 100%;
      display: flex;
      align-items: center;
      padding: 0 60px;
      box-sizing: border-box;
      position: relative;
    }

    /* Left Side: Text Content */
    .hero-text-content {
      width: 800px;
      max-width: 100%;
      z-index: 5;
      position: relative;
      display: flex;
      flex-direction: column;
      justify-content: center; /* Center vertically */
    }

    .hero-title {
      font-family: 'Lato', sans-serif;
      font-size: 72px;
      font-weight: 700;
      color: #000000;
      margin: 0 0 20px 0;
      line-height: 1.1;
      text-align: left;
      max-width: 700px;
      opacity: 0;
    }

    .hero-description {
      font-family: 'Work Sans', sans-serif;
      font-size: 18px;
      font-weight: 400;
      color: #666666;
      max-width: 650px;
      margin-bottom: 35px;
      line-height: 1.6;
      text-align: left;
      opacity: 0;
    }

    /* Action Bar (Button + Price) */
    .hero-action-bar {
      display: flex;
      align-items: center;
      gap: 30px;
      margin-bottom: 40px; /* Space before thumbnails */
      opacity: 0;
    }
    .hero-buy-btn {
      background-color: #d72e08;
      color: #ffffff;
      font-family: 'Work Sans', sans-serif;
      font-size: 16px;
      font-weight: 600;
      text-decoration: none;
      padding: 15px 35px;
      border-radius: 50px;
      display: inline-flex;
      align-items: center;
      gap: 10px;
      transition: background-color 0.3s ease;
    }
    .hero-buy-btn:hover {
      background-color: #b02406;
    }
    .hero-btn-arrow {
      width: 12px;
      height: 12px;
      fill: currentColor;
    }
    .hero-price-display {
      display: flex;
      align-items: center;
      gap: 12px;
      font-family: 'Work Sans', sans-serif;
    }
    .hero-price-now {
      font-size: 24px;
      font-weight: 700;
      color: #000;
    }
    .hero-price-was {
      font-size: 16px;
      font-weight: 400;
      color: #d72e08;
      text-decoration: line-through;
    }

    /* Thumbnails Row */
    .hero-slide-nav {
      display: flex;
      gap: 15px;
      opacity: 0; /* Also animate these in if desired */
      animation: heroFadeUp 0.8s cubic-bezier(0.2, 0.8, 0.2, 1) 0.4s forwards;
    }
    .hero-nav-item {
      width: 80px;
      height: 80px;
      border-radius: 8px;
      border: 1px solid #e5e5e5;
      padding: 5px;
      box-sizing: border-box;
      cursor: pointer;
      background: #fff;
      transition: all 0.3s ease;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .hero-nav-item.active {
      border: 2px solid #d72e08;
    }
    .hero-nav-item img {
      width: 100%;
      height: 100%;
      object-fit: contain;
    }

    /* Entrance Animations */
    @keyframes heroFadeUp {
      from {
        opacity: 0;
        transform: translateY(30px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }
    @keyframes heroImageZoom {
      from {
        opacity: 0;
        transform: scale(0.8) translateY(20px);
      }
      to {
        opacity: 1;
        transform: scale(1) translateY(-5px);
      }
    }

    .hero-slide.is-active .hero-title {
      animation: heroFadeUp 0.8s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
    }
    .hero-slide.is-active .hero-description {
      animation: heroFadeUp 0.8s cubic-bezier(0.2, 0.8, 0.2, 1) 0.2s forwards;
    }
    .hero-slide.is-active .hero-action-bar {
      animation: heroFadeUp 0.8s cubic-bezier(0.2, 0.8, 0.2, 1) 0.3s forwards;
    }
    .hero-slide.is-active .hero-featured-image {
      animation: heroImageZoom 1s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
    }

    /* Reset states */
    .hero-slide:not(.is-active) .hero-title,
    .hero-slide:not(.is-active) .hero-description,
    .hero-slide:not(.is-active) .hero-action-bar {
      opacity: 0;
    }
    .hero-slide:not(.is-active) .hero-featured-image {
      opacity: 0;
      transform: scale(0.8);
    }

    /* Right Side Visual */
    .hero-visual-content {
      flex: 1;
      height: 100%;
      display: flex;
      align-items: center;
      justify-content: center;
      z-index: 1;
    }
    .hero-prop-wrapper {
      position: relative;
      width: 500px;
      height: 500px;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .hero-red-prop {
      position: absolute;
      width: 100%;
      height: 100%;
      z-index: 1;
      object-fit: contain;
    }
    .hero-featured-image {
      position: relative;
      z-index: 2;
      max-width: 115%;
      max-height: 115%;
      object-fit: contain;
      transform: translateY(-5px);
    }

    /* Arrows */
    .hero-navigation-controls {
      position: absolute;
      bottom: 30px;
      left: 50%;
      transform: translateX(-50%);
      display: flex;
      gap: 20px;
      z-index: 15;
      align-items: center;
    }
    .hero-nav-arrow-prev,
    .hero-nav-arrow-next {
      width: 40px;
      height: 40px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      transition: all 0.3s;
    }
    .hero-nav-arrow-prev {
      background: transparent;
    } /* Per design? Or standard grey? keeping minimal */
    .hero-nav-arrow-prev svg {
      width: 16px;
      height: 16px;
      fill: #cccccc;
    }

    .hero-nav-arrow-next {
      background-color: #d72e08;
    }
    .hero-nav-arrow-next svg {
      width: 14px;
      height: 14px;
      fill: #ffffff;
    }

    @media screen and (max-width: 1024px) {
      .collection-hero {
        height: auto;
        padding-bottom: 0;
      }
      .hero-slide {
        flex-direction: column;
        padding: 10px 20px;
        height: auto;
        align-items: center;
      }
      .hero-text-content {
        display: contents;
      }
      .hero-visual-content {
        order: 1;
        width: 100%;
        height: auto;
        justify-content: center;
        margin-top: 0;
        margin-bottom: 5px;
      }
      .hero-title {
        order: 2;
        font-size: 24px;
        text-align: left;
        width: 100%;
        margin: 0 0 2px 0;
        opacity: 0;
      }
      .hero-description {
        order: 3;
        font-size: 14px;
        width: 100%;
        text-align: left;
        margin-bottom: 8px;
        opacity: 0;
      }
      .hero-action-bar {
        order: 4;
        display: flex;
        flex-direction: row;
        align-items: center;
        gap: 15px;
        margin-bottom: 10px;
        width: 100%;
        opacity: 0;
      }
      .hero-slide-nav {
        order: 5;
        justify-content: flex-start;
        gap: 10px;
        margin-bottom: 5px;
        width: 100%;
        align-items: center;
        opacity: 1 !important;
      }
      .hero-buy-btn {
        padding: 12px 25px;
        font-size: 14px;
        white-space: nowrap;
      }
      .hero-price-now {
        font-size: 18px;
      }
      .hero-price-was {
        font-size: 14px;
      }
      .hero-nav-item {
        width: 60px;
        height: 60px;
        flex-shrink: 0;
      }
      .hero-mobile-arrow {
        display: flex;
        cursor: pointer;
        align-items: center;
        justify-content: center;
        transition: transform 0.2s ease;
      }
      .hero-mobile-arrow-prev svg {
        width: 24px;
        height: 24px;
        fill: #cccccc;
      }
      .hero-mobile-arrow-next {
        width: 44px;
        height: 44px;
        border-radius: 50%;
        background-color: #d72e08;
      }
      .hero-mobile-arrow-next svg {
        width: 16px;
        height: 16px;
        fill: #ffffff;
      }
      .hero-prop-wrapper {
        width: 180px;
        height: 180px;
      }
      .hero-navigation-controls {
        display: none;
      }
      .desktop-desc {
        display: none !important;
      }
      .mobile-desc {
        display: block !important;
      }
    }

    /* Collection Banner Override Styles */
    .collection-banner-override {
      width: 100%;
      max-width: 1440px;
      margin: 0 auto;
      position: relative;
      border-radius: 20px;
      overflow: hidden;
      line-height: 0;
    }
    .collection-banner-img {
      width: 100%;
      height: auto;
      display: block;
      object-fit: cover;
    }
    .collection-banner-img.mobile-only {
      display: none;
    }
    @media screen and (max-width: 768px) {
      .collection-banner-img.desktop-only {
        display: none;
      }
      .collection-banner-img.mobile-only {
        display: block;
      }
    }

    /* Static Layout Styles */
    .hero-static-layout {
      width: 100%;
      height: 100%;
      position: relative;
      display: block;
      overflow: hidden;
    }
    .hero-static-layout img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }
    .hero-static-layout .mobile-only {
      display: none;
    }

    @media screen and (max-width: 768px) {
      .collection-hero {
        height: auto;
        min-height: 300px;
      }
      .hero-static-layout .desktop-only {
        display: none;
      }
      .hero-static-layout .mobile-only {
        display: block;
      }
      .hero-static-layout img {
        height: auto;
      }
      .hero-static-layout .static-overlay {
        position: relative;
        top: 0;
        left: 0;
        transform: none;
        padding: 20px;
        width: 100%;
      }
    }

    .hero-static-layout .static-overlay {
      position: absolute;
      top: 50%;
      left: 60px;
      transform: translateY(-50%);
      z-index: 10;
      pointer-events: none;
    }
    .hero-static-layout .static-overlay .hero-title,
    .hero-static-layout .static-overlay .hero-description {
      opacity: 1; /* Reset for static */
    }
  </style>

  {%- liquid
    assign active_override = false
    for block in section.blocks
      if block.type == 'collection_banner'
        if block.settings.collection_handle == collection.handle
          assign active_override = block
          break
        endif
      endif
    endfor
  -%}

  {%- if active_override -%}
    <div class="collection-banner-override" {{ active_override.shopify_attributes }}>
      {%- if active_override.settings.banner_link != blank -%}
        <a href="{{ active_override.settings.banner_link }}">
      {%- endif -%}

      {%- if active_override.settings.banner_image != blank -%}
        <img
          src="{{ active_override.settings.banner_image | image_url: width: 2200 }}"
          alt="{{ collection.title }}"
          class="collection-banner-img {% if active_override.settings.banner_mobile != blank %}desktop-only{% endif %}"
          width="1440"
          height="500"
          loading="eager"
        >
      {%- endif -%}

      {%- if active_override.settings.banner_mobile != blank -%}
        <img
          src="{{ active_override.settings.banner_mobile | image_url: width: 1000 }}"
          alt="{{ collection.title }}"
          class="collection-banner-img mobile-only"
          width="768"
          height="400"
          loading="eager"
        >
      {%- endif -%}

      {%- if active_override.settings.banner_link != blank -%}
        </a>
      {%- endif -%}
    </div>
  {%- elsif section.settings.hero_layout == 'static' or collection.metafields.custom.hero_layout == 'static' -%}
    <div class="hero-static-layout">
      {%- liquid
        # Determine source for static image (Metafield > Settings > Placeholder)
        assign static_img = collection.metafields.custom.hero_image | default: section.settings.static_image
        assign mobile_img = collection.metafields.custom.hero_image_mobile | default: section.settings.static_mobile_image | default: static_img
        assign static_lnk = collection.metafields.custom.hero_link | default: section.settings.static_link
        assign static_title = section.settings.static_title | default: collection.title
        assign static_desc = ""
        if section.settings.static_use_description and collection.description != blank
          assign static_desc = collection.description | strip_html
        endif
      -%}

      {%- if static_lnk != blank -%}<a href="{{ static_lnk }}">{%- endif -%}

      {%- if static_img != blank -%}
        <img
          src="{{ static_img | image_url: width: 2200 }}"
          alt="{{ collection.title }}"
          class="desktop-only"
          width="1440"
          height="680"
          loading="eager"
        >
      {%- else -%}
        {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg desktop-only' }}
      {%- endif -%}

      {%- if mobile_img != blank -%}
        <img
          src="{{ mobile_img | image_url: width: 1000 }}"
          alt="{{ collection.title }}"
          class="mobile-only"
          width="768"
          height="500"
          loading="eager"
        >
      {%- endif -%}

      {%- if static_lnk != blank -%}</a>{%- endif -%}

      {%- if static_title != blank or static_desc != blank -%}
        <div class="hero-text-content static-overlay">
          {%- if static_title != blank -%}
            <h1 class="hero-title" style="color: {{ section.settings.static_title_color }}; font-size: {{ section.settings.static_title_size }}px;">{{ static_title }}</h1>
          {%- endif -%}
          {%- if static_desc != blank -%}
            <div class="hero-description" style="color: {{ section.settings.static_desc_color }}; font-size: {{ section.settings.static_desc_size }}px;">
              <span class="desktop-desc">{{ static_desc | truncate: 150 }}</span>
              <span class="mobile-desc">{{ static_desc | truncatewords: 12 }}</span>
            </div>
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>
  {%- endif -%}

  {%- unless active_override
    and active_override.settings.hide_slider
    or section.settings.hero_layout == 'static'
    or collection.metafields.custom.hero_layout == 'static'
  -%}
    <div class="hero-slides-container" id="heroSlidesStrip-{{ section.id }}">
      {%- for block in section.blocks -%}
        {%- comment -%} Determine Product: Dynamic Collection OR Fallback Block {%- endcomment -%}
        {%- assign use_dynamic = false -%}
        {%- if collection.products_count > 0 and collection.handle != 'all' -%}
          {%- assign use_dynamic = true -%}
        {%- endif -%}

        {%- if use_dynamic -%}
          {%- assign product = collection.products[forloop.index0] -%}
        {%- else -%}
          {%- assign product = all_products[block.settings.product] -%}
        {%- endif -%}

        {%- if product == empty or product == blank -%}
          {%- comment -%}Fallback if dynamic collection has < 3 products, fallback to block{%- endcomment -%}
          {%- assign product = all_products[block.settings.product] -%}
        {%- endif -%}

        <div class="hero-slide" {{ block.shopify_attributes }}>
          <div class="hero-text-content">
            <!-- Text -->
            <h1 class="hero-title">
              {%- if section.settings.custom_collection_title != blank -%}
                {{ section.settings.custom_collection_title }}
              {%- elsif use_dynamic -%}
                {%- if product != empty -%}
                  {{ product.title }}
                {%- endif -%}
              {%- else -%}
                {%- if block.settings.heading != blank -%}
                  {{ block.settings.heading }}
                {%- elsif product != empty -%}
                  Trending {{ product.title }}
                {%- else -%}
                  {{ collection.title | default: 'Trending Collection' }}
                {%- endif -%}
              {%- endif -%}
            </h1>

            <div class="hero-description">
              {%- capture full_desc -%}
                {%- if section.settings.use_collection_description and collection.description != blank -%}
                  {{ collection.description | strip_html }}
                {%- elsif use_dynamic -%}
                  {%- if product != empty -%}
                    Explore our premium {{ collection.title }} collection.
                    {%- if product.description != blank -%}
                      {{ product.description | strip_html }}
                    {%- endif -%}
                  {%- endif -%}
                {%- else -%}
                  {%- if block.settings.description != blank -%}
                    {{ block.settings.description }}
                  {%- else -%}
                    Get a discount of 5% when you order this storage bag on our Black Friday Sales now!
                  {%- endif -%}
                {%- endif -%}
              {%- endcapture -%}

              <span class="desktop-desc">{{ full_desc | truncate: 150 }}</span>
              <span class="mobile-desc" style="display: none;">{{ full_desc | truncatewords: 12 }}</span>
            </div>

            <!-- Buttons & Price -->
            <div class="hero-action-bar">
              <a href="{% if product != empty %}{{ product.url }}{% else %}#{% endif %}" class="hero-buy-btn">
                Buy Now
                <svg class="hero-btn-arrow" viewBox="0 0 32 32" width="12" height="12">
                  <path d="M11 8l8 8-8 8 2 2 10-10-10-10z"/>
                </svg>
              </a>
              <div class="hero-price-display">
                <span class="hero-price-now">
                  {% if product != empty %}{{ product.price | money }}{% else %}$1,099.00{% endif %}
                </span>
                {%- if product != empty and product.compare_at_price > product.price -%}
                  <span class="hero-price-was">{{ product.compare_at_price | money }}</span>
                {%- endif -%}
              </div>
            </div>

            <!-- Thumbnails Row (Now below action bar) -->
            <div class="hero-slide-nav hero-nav-sync-{{ section.id }}">
              <div
                class="hero-mobile-arrow hero-mobile-arrow-prev"
                onclick="moveHeroPrev{{ section.id | replace: '-', '_' }}()"
              >
                <svg viewBox="0 0 32 32">
                  <path d="M21 24l-8-8 8-8-2-2-10 10 10 10z"/>
                </svg>
              </div>

              {%- for nav_block in section.blocks -%}
                {%- if use_dynamic -%}
                  {%- assign nav_product = collection.products[forloop.index0] -%}
                {%- else -%}
                  {%- assign nav_product = all_products[nav_block.settings.product] -%}
                {%- endif -%}

                {%- if nav_product == empty or nav_product == blank -%}
                  {%- comment -%}Fallback if even the block product is empty or collection has < 3 products{%- endcomment -%}
                  {%- assign nav_product = all_products[nav_block.settings.product] -%}
                {%- endif -%}

                <div
                  class="hero-nav-item {% if forloop.index0 == forloop.parentloop.index0 %}active{% endif %}"
                  onclick="jumpToHeroSlide{{ section.id | replace: '-', '_' }}({{ forloop.index0 }})"
                >
                  {%- if nav_product != empty -%}
                    <img
                      src="{{ nav_product.featured_image | image_url: width: 240 }}"
                      alt="{{ nav_product.title | escape }}"
                      width="{{ nav_product.featured_image.width }}"
                      height="{{ nav_product.featured_image.height }}"
                      loading="lazy"
                    >
                  {%- else -%}
                    {{ 'product-1' | placeholder_svg_tag }}
                  {%- endif -%}
                </div>
              {%- endfor -%}

              <div
                class="hero-mobile-arrow hero-mobile-arrow-next"
                onclick="moveHeroNext{{ section.id | replace: '-', '_' }}()"
              >
                <svg viewBox="0 0 32 32">
                  <path d="M11 8l8 8-8 8 2 2 10-10-10-10z"/>
                </svg>
              </div>
            </div>
          </div>

          <!-- Visual -->
          <div class="hero-visual-content">
            <div class="hero-prop-wrapper">
              <img
                src="{{ 'hero-red-circle.png' | asset_url }}"
                class="hero-red-prop"
                alt="Background decoration"
                width="600"
                height="600"
                loading="eager"
              >
              {%- if product != empty -%}
                <img
                  src="{{ product.featured_image | image_url: width: 1000 }}"
                  class="hero-featured-image"
                  alt="{{ product.title | escape }}"
                  width="{{ product.featured_image.width }}"
                  height="{{ product.featured_image.height }}"
                  loading="eager"
                >
              {%- else -%}
                <div
                  class="hero-featured-image"
                  style="width: 100%; max-width: 600px; height: auto; aspect-ratio: 1; opacity: 0.8;"
                >
                  {{ 'product-1' | placeholder_svg_tag }}
                </div>
              {%- endif -%}
            </div>
          </div>
        </div>
      {%- endfor -%}
    </div>

    <div class="hero-navigation-controls">
      <div class="hero-nav-arrow-prev" onclick="moveHeroPrev{{ section.id | replace: '-', '_' }}()">
        <svg viewBox="0 0 32 32">
          <path d="M21 24l-8-8 8-8-2-2-10 10 10 10z"/>
        </svg>
      </div>
      <div class="hero-nav-arrow-next" onclick="moveHeroNext{{ section.id | replace: '-', '_' }}()">
        <svg viewBox="0 0 32 32">
          <path d="M11 8l8 8-8 8 2 2 10-10-10-10z"/>
        </svg>
      </div>
    </div>
  {%- endunless -%}

  <script>
  (function() {
    let currentIdx = 0;
    const count = {{ section.blocks.size }};
    const strip = document.getElementById('heroSlidesStrip-{{ section.id }}');
    const syncClass = '.hero-nav-sync-{{ section.id }}';
    const slides = strip.querySelectorAll('.hero-slide');
    let autoplayTimer;

    function update() {
      if (!strip) return;
      strip.style.transform = `translateX(-${currentIdx * 100}%)`;
      
      slides.forEach((slide, idx) => {
        slide.classList.toggle('is-active', idx === currentIdx);
      });

      const allNavs = document.querySelectorAll(syncClass);
      allNavs.forEach(nav => {
        const items = nav.querySelectorAll('.hero-nav-item');
        items.forEach((item, idx) => {
          item.classList.toggle('active', idx === currentIdx);
        });
      });
      
      resetAutoplay();
    }

    function resetAutoplay() {
      clearInterval(autoplayTimer);
      autoplayTimer = setInterval(() => {
        window.moveHeroNext{{ section.id | replace: '-', '_' }}();
      }, 5000);
    }

    // Initial
    slides[0].classList.add('is-active'); 
    update();

    const wrapper = document.getElementById('heroCarouselWrapper-{{ section.id }}');
    wrapper.addEventListener('mouseenter', () => clearInterval(autoplayTimer));
    wrapper.addEventListener('mouseleave', () => resetAutoplay());

    window.moveHeroNext{{ section.id | replace: '-', '_' }} = function() {
      currentIdx = (currentIdx + 1) % count;
      update();
    };

    window.moveHeroPrev{{ section.id | replace: '-', '_' }} = function() {
      currentIdx = (currentIdx - 1 + count) % count;
      update();
    };

    window.jumpToHeroSlide{{ section.id | replace: '-', '_' }} = function(idx) {
      currentIdx = idx;
      update();
    };
  })();
  </script>
</div>

{% schema %}
{
  "name": "Collection Hero Carousel",
  "max_blocks": 5,
  "settings": [
    {
      "type": "select",
      "id": "hero_layout",
      "label": "Hero Layout",
      "options": [
        { "value": "slider", "label": "Product Slider" },
        { "value": "static", "label": "Static Graphic Banner" }
      ],
