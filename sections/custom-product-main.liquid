<script>
  // Image Gallery & Auto Slider
  const mainImage = document.getElementById('MainProductImage');
  const thumbnails = document.querySelectorAll('.thumbnail-item');
  const navDots = document.querySelectorAll('.nav-dot');
  let currentIndex = 0;
  let sliderInterval;
  const slideDelay = 5000; // 5 seconds

  // Collect all image URLs from thumbnails for slider
  const imageUrls = Array.from(thumbnails).map((thumb) =>
    thumb.querySelector('img').src.replace('width=200', 'width=800')
  );

  function updateSlider(index) {
    // Fade out
    mainImage.classList.add('fading');

    setTimeout(() => {
      if (imageUrls[index]) {
        mainImage.src = imageUrls[index];
      }
      mainImage.classList.remove('fading');
    }, 200); // 200ms matches half of CSS transition

    // Update active states
    thumbnails.forEach((t) => t.classList.remove('active'));
    navDots.forEach((d) => d.classList.remove('is-active-dot'));

    if (thumbnails[index]) thumbnails[index].classList.add('active');
    if (navDots[index]) navDots[index].classList.add('is-active-dot');

    currentIndex = index;

    // Sync mobile scroller if visible
    const mobileScroller = document.getElementById('MobileMediaScroller');
    if (mobileScroller && window.innerWidth <= 768) {
      const scrollPos = index * mobileScroller.offsetWidth;
      mobileScroller.scrollTo({ left: scrollPos, behavior: 'smooth' });
    }
  }

  // Mobile Swipe Synchronization
  const mobileScroller = document.getElementById('MobileMediaScroller');
  if (mobileScroller) {
    let isScrolling;
    mobileScroller.addEventListener('scroll', () => {
      window.clearTimeout(isScrolling);
      isScrolling = setTimeout(() => {
        const index = Math.round(mobileScroller.scrollLeft / mobileScroller.offsetWidth);
        if (index !== currentIndex) {
          currentIndex = index;
          navDots.forEach((d, i) => d.classList.toggle('is-active-dot', i === index));
          thumbnails.forEach((t, i) => t.classList.toggle('active', i === index));
          
          // Sync desktop main image just in case
          if (imageUrls[index]) {
             mainImage.src = imageUrls[index];
          }
        }
      }, 50); // Small debounce
    });
  }

  function scrollToImage(index) {
    stopAutoSlide();
    updateSlider(index);
    startAutoSlide();
  }

  function startAutoSlide() {
    stopAutoSlide(); // Clear existing to avoid multiples
    sliderInterval = setInterval(() => {
      let nextIndex = (currentIndex + 1) % imageUrls.length;
      updateSlider(nextIndex);
    }, slideDelay);
  }

  function stopAutoSlide() {
    if (sliderInterval) clearInterval(sliderInterval);
  }

  // Event Listeners for Thumbnails
  thumbnails.forEach((thumb, index) => {
    thumb.addEventListener('click', () => {
      stopAutoSlide(); // Pause on interaction
      updateSlider(index);
      startAutoSlide(); // Restart timer
    });
  });

  // Event Listeners for Dots
  navDots.forEach((dot, index) => {
    dot.addEventListener('click', () => {
      stopAutoSlide();
      if (thumbnails[index]) {
        updateSlider(index);
      }
      startAutoSlide();
    });
  });

  // Only start slider if more than one image
  if (imageUrls.length > 1) {
    startAutoSlide();
  }

  // Hover pauses slider
  const mainContainer = document.querySelector('.main-product-image-container');
  if (mainContainer) {
    mainContainer.addEventListener('mouseenter', stopAutoSlide);
    mainContainer.addEventListener('mouseleave', startAutoSlide);
  }

  // Toggle Other Options
  function toggleOtherOptions(id = 'OtherOptions') {
    const el = document.getElementById(id);
    if (el) el.classList.toggle('collapsed');
  }

  // Toggle Description Depth
  function toggleFullDescription(showFull) {
    const shortDesc = document.querySelector('.description-short');
    const fullDesc = document.querySelector('.description-full');
    
    if (showFull) {
      shortDesc.style.display = 'none';
      fullDesc.style.display = 'block';
    } else {
      shortDesc.style.display = 'block';
      fullDesc.style.display = 'none';
    }
  }

  // Toggle Specification
  function toggleSpecification() {
    document.getElementById('SpecSection').classList.toggle('collapsed');
  }

  // Variant Selection Logic
  window.handleVariantChange = function(radio) {
    // Update the label text 
    const optionName = radio.name.toLowerCase().replace(/[^a-z0-9]+/g, '-');
    const labelSpan = document.getElementById('selected-' + optionName);
    if (labelSpan) {
      labelSpan.textContent = radio.value;
    }

    // Get all selected options from radio buttons
    const selectedOptions = [];
    document.querySelectorAll('.variant-radio:checked').forEach(input => {
      selectedOptions[parseInt(input.getAttribute('data-option-index'))] = input.value;
    });

    // Find the matching variant from JSON
    const variantsDataElement = document.getElementById('product-variants-data');
    if (!variantsDataElement) return;

    try {
      const variants = JSON.parse(variantsDataElement.textContent);
      const matchedVariant = variants.find(variant => {
        return variant.options.every((option, index) => option === selectedOptions[index]);
      });

      if (matchedVariant) {
        // Update hidden input for Cart submission
        const variantIdInput = document.getElementById('ProductVariantId');
        if (variantIdInput) {
          variantIdInput.value = matchedVariant.id;
        }

        // Update price display
        const priceContainer = document.querySelector('.price-container');
        if (priceContainer) {
          const priceCurrent = priceContainer.querySelector('.price-current');
          if (priceCurrent) {
            priceCurrent.textContent = formatMoney(matchedVariant.price);
          }

          const priceOriginal = priceContainer.querySelector('.price-original');
          if (matchedVariant.compare_at_price > matchedVariant.price) {
            if (priceOriginal) {
              priceOriginal.textContent = formatMoney(matchedVariant.compare_at_price);
              priceOriginal.style.display = 'inline-block';
            } else {
              const newOriginal = document.createElement('span');
              newOriginal.className = 'price-original';
              newOriginal.textContent = formatMoney(matchedVariant.compare_at_price);
              priceContainer.appendChild(newOriginal);
            }
          } else if (priceOriginal) {
            priceOriginal.style.display = 'none';
          }
        }

        // Update Stock Status Text
        const stockText = document.querySelector('.stock-text');
        const addToCartBtn = document.querySelector('.btn-add-cart');
        const mobileAddToCartBtn = document.querySelector('.mobile-sticky-bar .btn-add-cart');
        
        if (stockText && addToCartBtn) {
          if (matchedVariant.available) {
            if (matchedVariant.inventory_management === 'shopify' && matchedVariant.inventory_quantity <= 0) {
              stockText.innerHTML = '<span style="color: #2e7d32;">Available on only pre-order</span>';
              addToCartBtn.textContent = "Pre-Order Now";
              if (mobileAddToCartBtn) mobileAddToCartBtn.textContent = "Pre-Order Now";
            } else {
              stockText.textContent = "In stock";
              addToCartBtn.textContent = "Add to Cart";
              if (mobileAddToCartBtn) mobileAddToCartBtn.textContent = "Add to Cart";
            }
            addToCartBtn.disabled = false;
            if (mobileAddToCartBtn) mobileAddToCartBtn.disabled = false;
          } else {
            stockText.textContent = "Out of stock";
            addToCartBtn.textContent = "Sold Out";
            if (mobileAddToCartBtn) mobileAddToCartBtn.textContent = "Sold Out";
            addToCartBtn.disabled = true;
            if (mobileAddToCartBtn) mobileAddToCartBtn.disabled = true;
          }
        }

        // Update URL
        const newUrl = new URL(window.location.href);
        newUrl.searchParams.set('variant', matchedVariant.id);
        window.history.replaceState({ path: newUrl.href }, '', newUrl.href);

        // Update Main Image if variant has an image
        if (matchedVariant.featured_image) {
          const mainImage = document.getElementById('MainProductImage');
          if (mainImage) {
            mainImage.src = matchedVariant.featured_image.src;
          }
          // Update thumbnails active state
          const thumbnails = document.querySelectorAll('.product-thumbnail');
          thumbnails.forEach(thumb => {
            // Try to match thumbnail's image id
            if (thumb.querySelector('img').src.includes(matchedVariant.featured_image.src.split('?')[0])) {
               document.querySelectorAll('.product-thumbnail').forEach(t => t.classList.remove('active'));
               thumb.classList.add('active');
            }
          });
        }
      }
    } catch(e) {
      console.error('Error updating variant', e);
    }
  };

  function formatMoney(cents) {
    if (!cents) return "$0.00";
    return "$" + (cents / 100).toFixed(2);
  }

  // Quantity Controls
  function incrementQuantity(inputId = 'Quantity') {
    const input = document.getElementById(inputId);
    if(input) {
      input.value = parseInt(input.value) + 1;
      syncQuantity(input.value);
    }
  }

  function decrementQuantity(inputId = 'Quantity') {
    const input = document.getElementById(inputId);
    if (input && parseInt(input.value) > 1) {
      input.value = parseInt(input.value) - 1;
      syncQuantity(input.value);
    }
  }

  // Sync Quantity between Desktop and Mobile inputs
  function syncQuantity(value) {
    const desktopInput = document.getElementById('Quantity');
    const mobileInput = document.getElementById('MobileQuantity');
    
    if (desktopInput) desktopInput.value = value;
    if (mobileInput) mobileInput.value = value;
  }

  // Add to Cart - Trigger Popup
  function addToCart() {
    if ({{ section.settings.show_addon_popup | json }}) {
      openAddonPopup();
    } else {
      proceedToCart(false);
    }
  }

  // Popup Management
  function openAddonPopup() {
    const overlay = document.getElementById('AddonPopupOverlay');
    if (overlay) overlay.style.display = 'flex';
    document.body.style.overflow = 'hidden'; // Prevent scroll
  }

  function closeAddonPopup() {
    const overlay = document.getElementById('AddonPopupOverlay');
    if (overlay) overlay.style.display = 'none';
    document.body.style.overflow = ''; // Restore scroll
  }

  function toggleAddonSelection(checkbox) {
    const wrapper = checkbox.closest('.addon-item-wrapper');
    const card = wrapper.querySelector('.addon-product-card');
    if (checkbox.checked) {
      card.style.borderColor = '#d72e08';
      card.style.backgroundColor = '#fffaf9';
    } else {
      card.style.borderColor = '#f0f0f0';
      card.style.backgroundColor = '#fff';
    }
  }

  // Proceed logic for Popup
  async function proceedToCart(includeAddons) {
    const quantityElement = document.getElementById('Quantity');
    const mainQuantity = quantityElement ? parseInt(quantityElement.value) : 1;
    
    // Get the selected variant ID dynamically
    const variantIdInput = document.getElementById('ProductVariantId');
    const mainVariantId = variantIdInput ? parseInt(variantIdInput.value) : {{ product.selected_or_first_available_variant.id }};

    let itemsToAdd = [{
      'id': mainVariantId,
      'quantity': mainQuantity
    }];

    if (includeAddons) {
      const selectedAddons = document.querySelectorAll('.addon-checkbox:checked');
      selectedAddons.forEach(checkbox => {
        const wrapper = checkbox.closest('.addon-item-wrapper');
        const variantId = wrapper.getAttribute('data-variant-id');
        if (variantId) {
          itemsToAdd.push({
            'id': parseInt(variantId),
            'quantity': 1
          });
        }
      });
    }

    // Add everything to cart using AJAX
    try {
      const response = await fetch(window.Shopify.routes.root + 'cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ 'items': itemsToAdd })
      });
      
      const data = await response.json();
      console.log('Cart updated:', data);
      window.location.href = '/cart';
    } catch (error) {
      console.error('Error adding to cart:', error);
      alert('There was an error adding items to your cart. Please try again.');
    } finally {
      closeAddonPopup();
    }
  }

  // Quick Add to Cart for Other Options
  async function quickAddToCart(event, variantId) {
    if (event) {
      event.preventDefault();
      event.stopPropagation();
    }
    
    const btn = event.currentTarget;
    btn.classList.add('loading');
    const originalIcon = btn.innerHTML;
    
    // Show spinner
    btn.innerHTML = '<svg class="spinner" viewBox="0 0 50 50" style="animation: rotate 2s linear infinite; width: 20px; height: 20px;"><circle cx="25" cy="25" r="20" fill="none" stroke="currentColor" stroke-width="5" stroke-dasharray="90,150" stroke-dashoffset="0" style="stroke-linecap: round;"></circle></svg>';

    try {
      const response = await fetch(window.Shopify.routes.root + 'cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          'items': [{
            'id': variantId,
            'quantity': 1
          }]
        })
      });
      
      const data = await response.json();
      
      if (response.ok) {
        btn.classList.remove('loading');
        btn.classList.add('success');
        btn.innerHTML = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"></polyline></svg>';
        
        // Optional: Trigger cart drawer update if exists
        if (typeof publish === 'function') {
          publish(PUB_SUB_EVENTS.cartUpdate, {source: 'product-form'});
        }
        
        // Reset button after 2 seconds
        setTimeout(() => {
          btn.classList.remove('success');
          btn.innerHTML = originalIcon;
        }, 2000);
      } else {
        throw new Error(data.description || 'Error adding to cart');
      }
    } catch (error) {
      console.error('Quick add error:', error);
      btn.classList.remove('loading');
      btn.innerHTML = originalIcon;
      alert(error.message);
    }
  }

  // Save for Later
  function saveForLater() {
    // Implement save for later logic
    console.log('Saved for later');
  }

  // Countdown timer removed


  // ========== ABOUT & REVIEWS SECTION ==========
  // Tab Switching
  const tabBtns = document.querySelectorAll('.tab-btn');
  const tabContents = document.querySelectorAll('.tab-content');

  tabBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      const tabName = btn.getAttribute('data-tab');
      switchTab(tabName);
    });
  });

  function switchTab(tabName) {
    // Remove active class from all tabs and contents
    tabBtns.forEach((btn) => btn.classList.remove('active'));
    tabContents.forEach((content) => content.classList.remove('active'));

    // Add active class to selected tab and content
    const activeBtn = document.querySelector(`[data-tab="${tabName}"]`);
    const activeContent = document.getElementById(`${tabName}-tab`);

    if (activeBtn) activeBtn.classList.add('active');
    if (activeContent) activeContent.classList.add('active');

    // Fix for Judge.me masonry layout when tab is first shown
    if (tabName === 'reviews') {
      setTimeout(() => {
        window.dispatchEvent(new Event('resize'));
        // Also try specific Judge.me refresh if available
        if (window.jdgm && window.jdgm.onInstalled) {
          window.jdgm.onInstalled();
        }
      }, 100);
    }
  }

  // Section Toggle
  function toggleSection(sectionId) {
    const section = document.getElementById(sectionId);
    if (section) {
      section.classList.toggle('collapsed');
    }
  }

  // Carousel Scroll
  function scrollCarousel(sectionId, direction) {
    const section = document.getElementById(sectionId);
    if (!section) return;

    const track = section.querySelector('.carousel-track');
    if (!track) return;

    const scrollAmount = 350; // Match card width (320px) + gap (30px)
    track.scrollLeft += scrollAmount * direction;
  }

  // Force Download Logic for Document Links (Ensures .pdf extension)
  document.querySelectorAll('.download-link:not(.download-link--unavailable)').forEach(link => {
    link.addEventListener('click', async (e) => {
      const url = link.getAttribute('href');
      let filename = link.getAttribute('download') || 'document.pdf';
      if (!filename.toLowerCase().endsWith('.pdf')) filename += '.pdf';
      
      if (url && url !== '#' && !url.startsWith('javascript:')) {
        // Only intercept if it looks like a PDF or direct file link
        if (url.toLowerCase().includes('.pdf') || url.toLowerCase().includes('files/')) {
          e.preventDefault();
          
          try {
            const response = await fetch(url);
            if (!response.ok) throw new Error('Download failed');
            
            const blob = await response.blob();
            const blobUrl = window.URL.createObjectURL(blob);
            
            const tempLink = document.createElement('a');
            tempLink.href = blobUrl;
            tempLink.download = filename;
            document.body.appendChild(tempLink);
            tempLink.click();
            document.body.removeChild(tempLink);
            window.URL.revokeObjectURL(blobUrl);
          } catch (error) {
            console.error('JS Download failed, falling back to native link:', error);
            window.open(url, '_blank');
          }
        }
      }
    });
  });
</script>

<!-- Warranty Modal Structure -->
<div id="WarrantyModal" class="warranty-modal-overlay">
  <div class="warranty-modal-container">
    <button class="warranty-modal-close" onclick="closeWarrantyModal()" aria-label="Close Modal">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
    </button>
    <div id="WarrantyModalLoader" class="warranty-modal-loader">
      <div class="spinner"></div>
      <span class="loader-text">Loading Details...</span>
    </div>
    <div id="WarrantyModalBody" class="warranty-modal-body" style="overflow-y: auto;">
      <!-- Content injected here via JS -->
    </div>
  </div>
</div>

<script>
  async function openWarrantyModal(event) {
    if (event) event.preventDefault();
    const modal = document.getElementById('WarrantyModal');
    const body = document.getElementById('WarrantyModalBody');
    const loader = document.getElementById('WarrantyModalLoader');
    
    // Lock scroll
    document.body.style.overflow = 'hidden';
    
    modal.style.display = 'flex';
    setTimeout(() => modal.classList.add('active'), 10);
    
    loader.style.display = 'flex';
    body.innerHTML = '';
    
    try {
      const response = await fetch('/pages/warranty');
      const html = await response.text();
      const parser = new DOMParser();
      const doc = parser.parseFromString(html, 'text/html');
      
      const content = doc.querySelector('main') || doc.querySelector('#MainContent') || doc.querySelector('.main-content');
      
      if (content) {
        // Remove header/footer if they leaked into main
        const header = content.querySelector('header');
        const footer = content.querySelector('footer');
        if (header) header.remove();
        if (footer) footer.remove();

        body.innerHTML = content.innerHTML;
        
        // Trigger animations for our new premium sections
        // Small delay to ensure DOM is ready for classes
        setTimeout(() => {
          // 1. Activate staggered reveals
          const staggers = body.querySelectorAll('.reveal-stagger');
          staggers.forEach((el, index) => {
            setTimeout(() => {
              el.classList.add('active');
            }, index * 40); // Slightly faster stagger for modals
          });

          // 2. Activate Hero section
          const heroes = body.querySelectorAll('[id^="PremiumHero-"]');
          heroes.forEach(hero => {
            hero.classList.add('is-loaded');
          });

          // 3. Fallback for any legacy triggers
          const legacyTriggers = body.querySelectorAll('.premium-scroll-trigger, .scroll-trigger-title');
          legacyTriggers.forEach(el => el.classList.add('is-visible'));
        }, 100);
      } else {
        body.innerHTML = '<div style="padding:60px; text-align:center;"><p>Unable to load detailed warranty information. Please check back later.</p></div>';
      }
    } catch (e) {
      body.innerHTML = '<div style="padding:60px; text-align:center;"><p>Error connecting to server. Please try again.</p></div>';
    } finally {
      loader.style.display = 'none';
    }
  }

  function closeWarrantyModal() {
    const modal = document.getElementById('WarrantyModal');
    modal.classList.remove('active');
    
    // Unlock scroll
    document.body.style.overflow = '';
    
    setTimeout(() => {
      modal.style.display = 'none';
      document.getElementById('WarrantyModalBody').innerHTML = '';
    }, 400);
  }

  // Close on outside click
  window.addEventListener('click', (e) => {
    const modal = document.getElementById('WarrantyModal');
    if (e.target === modal) {
      closeWarrantyModal();
    }
  });

  // Close on Escape
  window.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      closeWarrantyModal();
    }
  });
</script>

