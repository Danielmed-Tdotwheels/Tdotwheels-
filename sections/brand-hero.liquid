{% comment %} Brand Hero Section {% endcomment %}
<style>
  .brand-hero-section {
    position: relative;
    width: 100%;
    height: 383px;
    overflow: hidden;
  }

  .brand-hero-background {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 1;
  }

  .brand-hero-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, {{ section.settings.overlay_opacity | divided_by: 100.0 }});
    z-index: 2;
  }

  .brand-hero-content {
    position: relative;
    z-index: 3;
    max-width: 1440px;
    margin: 0 auto;
    padding: 0 60px;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .brand-hero-breadcrumb {
    font-family: 'Work Sans', sans-serif;
    font-size: 16px;
    font-weight: 400;
    color: #ffffff;
    margin-bottom: 20px;
    opacity: 0.9;
  }

  .brand-hero-breadcrumb a {
    color: #ffffff;
    text-decoration: none;
    transition: opacity 0.3s ease;
  }

  .brand-hero-breadcrumb a:hover {
    opacity: 0.7;
  }

  .brand-hero-breadcrumb-separator {
    margin: 0 8px;
  }

  .brand-hero-heading {
    font-family: 'Lato', sans-serif;
    font-size: 64px;
    font-weight: 700;
    color: #ffffff;
    line-height: 1.2;
    margin: 0 0 20px 0;
    text-align: left;
    max-width: 800px;
  }

  .brand-hero-description {
    font-family: 'Work Sans', sans-serif;
    font-size: 14px;
    font-weight: 400;
    color: #ffffff;
    line-height: 1.6;
    margin: 0;
    max-width: 600px;
    opacity: 0.95;
  }

  /* Mobile Responsive */
  @media screen and (max-width: 768px) {
    .brand-hero-section {
      height: 300px;
    }

    .brand-hero-content {
      padding: 0 20px;
    }

    .brand-hero-breadcrumb {
      font-size: 14px;
      margin-bottom: 15px;
    }

    .brand-hero-heading {
      font-size: 36px;
      margin-bottom: 15px;
    }

    .brand-hero-description {
      font-size: 13px;
    }
  }

  @media screen and (max-width: 480px) {
    .brand-hero-section {
      height: 250px;
    }

    .brand-hero-heading {
      font-size: 28px;
    }

    .brand-hero-description {
      font-size: 12px;
    }
  }
</style>

<section class="brand-hero-section">
  {%- liquid
    assign hero_img = section.settings.background_image
    if collection.image != blank and hero_img == blank
      assign hero_img = collection.image
    endif
  -%}

  {% if hero_img != blank %}
    <img
      src="{{ hero_img | image_url: width: 1920 }}"
      alt="{{ collection.title | default: section.settings.heading | escape }}"
      class="brand-hero-background"
      loading="eager"
      width="1920"
      height="383"
    >
  {% else %}
    <img
      src="{{ 'brand-bg.jpg' | asset_url }}"
      alt="{{ collection.title | default: section.settings.heading | escape }}"
      class="brand-hero-background"
      loading="eager"
      width="1920"
      height="383"
    >
  {% endif %}

  <div class="brand-hero-overlay"></div>

  <div class="brand-hero-content">
    <div class="brand-hero-breadcrumb">
      <a href="/pages/brands">Shop by Brands</a>
      <span class="brand-hero-breadcrumb-separator">></span>
      <span>{{ collection.title | default: section.settings.brand_name }}</span>
    </div>

    <h1 class="brand-hero-heading">
      {%- if collection -%}
        {%- if collection.title == 'Pidzoom' -%}
          Ride Safe And Charge Safe
        {%- else -%}
          {{ collection.title }}
        {%- endif -%}
      {%- else -%}
        {{ section.settings.heading }}
      {%- endif -%}
    </h1>

    <div class="brand-hero-description">
      {%- if collection.description != blank -%}
        {{ collection.description }}
      {%- else -%}
        {{ section.settings.description }}
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Brand Hero",
  "settings": [
    {
      "type": "text",
      "id": "brand_name",
      "label": "Brand Name (Fallback)",
      "default": "Ryvo-X Collection"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading (Fallback)",
      "default": "Performance-Driven Electric Mobility"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description (Fallback)",
      "default": "Built with high-performance components and precision handling, Ryvo-X delivers a bold riding experience designed for speed, stability, and urban performance."
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background Image override",
      "info": "If left blank, will use collection image or default brand-bg.jpg"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 90,
      "step": 10,
      "default": 70,
      "unit": "%",
      "label": "Overlay Opacity"
    }
  ],
  "presets": [
    {
      "name": "Brand Hero"
    }
  ]
}
{% endschema %}
