<style>
  .brand-lifestyle-section-{{ section.id }} {
    width: 100%;
    height: 312px;
    background-image: url('{{ "inn.jpg" | asset_url }}');
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    display: flex;
    align-items: center;
    position: relative;
    margin: 60px 0;
    overflow: hidden;
  }

  .brand-lifestyle-overlay-{{ section.id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.3); /* Optional overlay for readability */
    z-index: 1;
  }

  .brand-lifestyle-content-{{ section.id }} {
    position: relative;
    z-index: 2;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .brand-lifestyle-heading-{{ section.id }} {
    font-family: 'Lato', sans-serif;
    font-size: 36px;
    font-weight: 700;
    color: #ffffff;
    margin: 0 auto 15px;
    max-width: 523px;
    height: auto;
    line-height: 1.2;
  }

  .brand-lifestyle-description-{{ section.id }} {
    font-family: 'Work Sans', sans-serif;
    font-size: 16px;
    font-weight: 400;
    color: #ffffff;
    margin: 0 auto;
    max-width: 523px;
    height: auto;
    line-height: 1.5;
  }

  @media screen and (max-width: 768px) {
    .brand-lifestyle-section-{{ section.id }} {
      height: 236px;
      margin: 30px 0;
    }
    .brand-lifestyle-content-{{ section.id }} {
      align-items: flex-start;
      text-align: left;
    }
    .brand-lifestyle-heading-{{ section.id }} {
      font-size: 28px;
      max-width: 90%;
      margin: 0 0 10px 0;
    }
    .brand-lifestyle-description-{{ section.id }} {
      font-size: 12px;
      max-width: 90%;
      margin: 0;
    }
  }
</style>

<div class="brand-lifestyle-section-{{ section.id }}">
  <div class="brand-lifestyle-overlay-{{ section.id }}"></div>
  <div class="brand-lifestyle-content-{{ section.id }} page-width">
    <h2 class="brand-lifestyle-heading-{{ section.id }}">
      {{ section.settings.heading | default: 'HD Display Everything At A Glance' }}
    </h2>
    <p class="brand-lifestyle-description-{{ section.id }}">
      {{
        section.settings.description
        | default: 'Stay informed on the go with a sleek LCD screen displaying speed, battery life, and ride mode at a glance.'
      }}
    </p>
  </div>
</div>

{% schema %}
{
  "name": "Brand Lifestyle Feature",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "HD Display Everything At A Glance" },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Stay informed on the go with a sleek LCD screen displaying speed, battery life, and ride mode at a glance."
    }
  ],
  "presets": [
    {
      "name": "Brand Lifestyle Feature"
    }
  ]
}
{% endschema %}
