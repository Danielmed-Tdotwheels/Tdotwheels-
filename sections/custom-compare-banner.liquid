<style>
  .compare-banner-section {
    max-width: 1440px;
    margin: 60px auto;
    padding: 0 60px;
  }
  .compare-banner-container {
    position: relative;
    width: 100%;
    height: 420px;
    border-radius: 24px;
    overflow: hidden;
    background-color: {{ section.settings.banner_bg_color }};
    display: flex;
    align-items: center;
  }
  .compare-banner-bg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 1;
  }
  .compare-banner-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, rgba(0,0,0,0.4) 0%, rgba(0,0,0,0.1) 50%, rgba(0,0,0,0) 100%);
    z-index: 2;
  }
  .compare-banner-content {
    position: relative;
    z-index: 3;
    padding: 0 80px;
    max-width: 650px;
    color: {{ section.settings.text_color }};
  }
  .compare-banner-heading {
    font-family: 'Lato', sans-serif;
    font-size: 48px;
    font-weight: 700;
    margin: 0 0 15px 0;
    line-height: 1.1;
  }
  .compare-banner-subheading {
    font-family: 'Work Sans', sans-serif;
    font-size: 18px;
    font-weight: 400;
    margin-bottom: 35px;
    opacity: 0.95;
    line-height: 1.4;
  }
  .compare-banner-btn {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    background: #d72308;
    color: #ffffff;
    padding: 16px 32px;
    border-radius: 50px;
    text-decoration: none;
    font-family: 'Work Sans', sans-serif;
    font-size: 16px;
    font-weight: 600;
    transition: all 0.3s ease;
    box-shadow: 0 4px 15px rgba(215, 35, 8, 0.3);
  }
  .compare-banner-btn:hover {
    background: #f12c0a;
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(215, 35, 8, 0.4);
  }
  .compare-banner-btn svg {
    width: 20px;
    height: 20px;
  }

  @media screen and (max-width: 1024px) {
    .compare-banner-section {
      padding: 0 30px;
    }
    .compare-banner-content {
      padding: 0 40px;
    }
    .compare-banner-heading {
      font-size: 36px;
    }
  }
  @media screen and (max-width: 768px) {
    .compare-banner-section {
      margin: 40px auto;
      padding: 0 20px;
    }
    .compare-banner-container {
      height: 380px;
      padding: 40px 0;
      align-items: flex-end;
    }
    .compare-banner-content {
      padding: 0 30px;
      text-align: left;
    }
    .compare-banner-heading {
      font-size: 28px;
    }
    .compare-banner-subheading {
      font-size: 16px;
      margin-bottom: 25px;
    }
    .compare-banner-btn {
      padding: 14px 28px;
      font-size: 14px;
    }
    .compare-banner-overlay {
      background: linear-gradient(0deg, rgba(0,0,0,0.6) 0%, rgba(0,0,0,0.2) 60%, rgba(0,0,0,0.1) 100%);
    }
  }
</style>

<div class="compare-banner-section" id="CompareBanner-{{ section.id }}">
  <div class="compare-banner-container">
    {%- if section.settings.banner_image != blank -%}
      <img
        src="{{ section.settings.banner_image | image_url: width: 2000 }}"
        alt="{{ section.settings.heading | escape }}"
        class="compare-banner-bg"
        loading="lazy"
        width="{{ section.settings.banner_image.width }}"
        height="{{ section.settings.banner_image.height }}"
      >
    {%- else -%}
      {{ 'lifestyle-1' | placeholder_svg_tag: 'compare-banner-bg placeholder-svg' }}
    {%- endif -%}

    <div class="compare-banner-overlay"></div>

    <div class="compare-banner-content">
      <h2 class="compare-banner-heading">{{ section.settings.heading }}</h2>
      <p class="compare-banner-subheading">{{ section.settings.subheading }}</p>
      <a href="{{ section.settings.button_link | default: '/pages/compare-1' }}" class="compare-banner-btn">
        {{ section.settings.button_text }}
        <svg
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <polyline points="9 18 15 12 9 6"></polyline>
        </svg>
      </a>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Compare Page Banner",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Find Your Perfect Ride"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Compare our top-rated products side-by-side to find the one that fits your lifestyle."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Start Comparing"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "image_picker",
      "id": "banner_image",
      "label": "Banner Background Image"
    },
    {
      "type": "color",
      "id": "banner_bg_color",
      "label": "Fallback Background Color",
      "default": "#f8f8f8"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#ffffff"
    }
  ],
  "presets": [
    {
      "name": "Compare Page Banner"
    }
  ]
}
{% endschema %}
